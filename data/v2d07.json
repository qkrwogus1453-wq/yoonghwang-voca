 듀스 / 액운","p":[{"d":"2의 눈","s":["two"]},{"d":"듀스","s":["tie"]}],"s":["two","tie"],"r":"[프랑스어] deux(둘) ← 라틴어 duo(둘) → 주사위 2의 눈 → 2의 눈, 듀스","type":"word","src":"Y"},{"id":9216,"vol":2,"day":7,"w":"deus ex machina","m":"위급함을 구해주는 기적 / 급할 때 나타나서 돕는 신(고전극에서)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The sudden rescue felt like a deus ex machina.","ko":"그 갑작스러운 구조는 급할 때 나타난 기적 같았다."}},{"id":9217,"vol":2,"day":7,"w":"devalue = devaluate","m":"가치를 감소시키다 / 평가 절하하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The crisis devalued the country's currency.","ko":"그 위기가 그 나라의 통화를 평가 절하시켰다."}},{"id":9218,"vol":2,"day":7,"w":"devitalize","m":"~의 활력을 빼앗다","p":[{"d":"~의 활력을 빼앗다","s":["weaken"]}],"s":["weaken"],"r":"de(반대/없애다) + vital(활력의) + -ize(make/만들다) → 활력을 없애다 → ~의 활력을 빼앗다","type":"word","src":"Y"},{"id":9219,"vol":2,"day":7,"w":"devolution","m":"퇴화 / 위임 / 권리 이양","p":[{"d":"퇴화","s":["degeneration"]}],"s":["degeneration"],"r":"de(down/아래로) + volut(roll/굴리다) + -ion(명사형) → 아래로 굴러 내림 → 퇴화, 위임, 권리 이양","type":"word","src":"Y"},{"id":9220,"vol":2,"day":7,"w":"diabolic","m":"악마 같은","p":[{"d":"악마 같은","s":["fiendish"]}],"s":["fiendish"],"r":"diabol(devil/악마) + -ic(형용사형) → 악마의 → 악마 같은","type":"word","src":"Y"},{"id":9221,"vol":2,"day":7,"w":"diadem","m":"왕관 / 장식 머리띠","p":[{"d":"왕관","s":["crown"]}],"s":["crown"],"r":"dia(through/두루) + dem(bind/묶다) → 머리에 두른 띠 → 왕관, 장식 머리띠","type":"word","src":"Y"},{"id":9222,"vol":2,"day":7,"w":"diagonal","m":"대각선의 / 대각선","p":[],"s":[],"r":"dia(through) + gon(angle/각도) → 각을 가로질러 → 대각선의","type":"word","src":"Y"},{"id":9223,"vol":2,"day":7,"w":"diagrammatic","m":"도표의 / 개략적인","p":[{"d":"도표의 / 개략적인","s":["sketchy"]}],"s":["sketchy"],"r":"diagram(도표) + -matic(형용사형) → 도표로 나타낸 → 도표의, 개략적인","type":"word","src":"Y"},{"id":9224,"vol":2,"day":7,"w":"dialogic","m":"대화체의","p":[],"s":[],"r":"dia(through/서로) + log(speak/말하다) + -ic(형용사형) → 서로 말을 주고받는 → 대화체의","type":"word","src":"Y"},{"id":9225,"vol":2,"day":7,"w":"die hard","m":"쉽게 사라지지 않다","