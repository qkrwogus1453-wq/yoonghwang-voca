":"semi(half/반) + conductor(도체) → 반쯤 통하는 것 → 반도체","type":"word","src":"Y"},{"id":11886,"vol":2,"day":24,"w":"semiotics = semiology","m":"기호학","p":[{"d":"기호학","s":["science of signs"]}],"s":["science of signs"],"r":"","type":"phrase","src":"Y","ex":{"en":"Semiotics studies how signs carry meaning.","ko":"기호학은 기호가 어떻게 의미를 전달하는지 연구한다."}},{"id":11887,"vol":2,"day":24,"w":"send in","m":"출품하다 / 제출하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She sent in her application before the deadline.","ko":"그녀는 마감 전에 지원서를 제출했다."}},{"id":11888,"vol":2,"day":24,"w":"send ~ in","m":"~를 들어오게 하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Please send in the next candidate.","ko":"다음 지원자를 들어오게 해 주세요."}},{"id":11889,"vol":2,"day":24,"w":"send out","m":"보내다 / 발송하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The office sent out the invitations yesterday.","ko":"그 사무실은 어제 초대장을 발송했다."}},{"id":11890,"vol":2,"day":24,"w":"senescence","m":"노쇠 / 노령","p":[],"s":[],"r":"senesc(grow old/늙다) + -ence(명사형) → 늙어감 → 노쇠, 노령","type":"word","src":"Y"},{"id":11891,"vol":2,"day":24,"w":"seniority","m":"상급자임 / 연공 서열","p":[],"s":[],"r":"senior(연장자) + -ity(명사형) → 연장자임 → 상급자임, 연공 서열","type":"word","src":"Y"},{"id":11892,"vol":2,"day":24,"w":"senseless","m":"무분별한 / 인사 불성의","p":[],"s":[],"r":"sense(분별) + -less(없는) → 분별이 없는 → 무분별한, 인사 불성의","type":"word","src":"Y"},{"id":11893,"vol":2,"day":24,"w":"sententious","m":"격언식의 / 훈계조의 / 간결한","p":[{"d":"격언식의 / 훈계조의 / 간결한","s":["terse"]}],"s":["terse"],"r":"sent(ent)(feel/생각) + -ious(형용사형) → 생각을 짧게 담은 → 격언식의, 훈계조의, 간결한","type":"word","src":"Y"},{"id":11894,"vol":2,"day":24,"w":"septic","m":"부패성의 / 전염성의","p":[{"d":"부패성의 / 전염성의","s":["infected"]}],"s":["infected"],"r":"sept(ic)(rot/썩다) → 썩게 하는 → 부패성의, 전염성의","type":"word","src":"Y"},{"id":11895,"vol":2,"day":24,"w":"septuagenarian","m":"70대의 사람","p":[],"s":[],"r":"septua(seventy/일흔) + gen(태어난) + -arian(~하는 사람) → 일흔 대의 → 70대의 사람","type":"word","src":"Y"},{"id":11896,"vol":2,"day":24