[{"id":11831,"vol":2,"day":24,"w":"screed","m":"길고 지루한 이야기 / 장광설","p":[{"d":"길고 지루한 이야기 / 장광설","s":["harangue"]}],"s":["harangue"],"r":"[screed, 긴 이야기] ← 고대 영어 screade(조각) → 길게 늘어놓는 말 → 길고 지루한 이야기, 장광설","type":"word","src":"Y"},{"id":11832,"vol":2,"day":24,"w":"scribble","m":"갈겨쓰다 / 낙서하다","p":[{"d":"갈겨쓰다","s":["scrawl"]}],"s":["scrawl"],"r":"[scribble, 갈겨쓰다] ← 라틴어 scribere(write/쓰다) → 아무렇게나 쓰다 → 갈겨쓰다, 낙서하다","type":"word","src":"Y"},{"id":11833,"vol":2,"day":24,"w":"scrimmage","m":"난투","p":[{"d":"난투","s":["fight"]}],"s":["fight"],"r":"[scrimmage, 뒤엉킴] ← skirmish(작은 접전)의 변형 → 뒤엉켜 싸움 → 난투","type":"word","src":"Y"},{"id":11834,"vol":2,"day":24,"w":"scrimp","m":"절약하다 / 긴축하다","p":[{"d":"절약하다","s":["skimp"]}],"s":["skimp"],"r":"[scrimp, 인색하게 굴다] → 바짝 아끼다 → 절약하다, 긴축하다","type":"word","src":"Y"},{"id":11835,"vol":2,"day":24,"w":"scrounge","m":"얻어가다 / 우려내다","p":[{"d":"얻어가다","s":["obtain"]}],"s":["obtain"],"r":"[scrounge, 우려내다] → 얻어 챙기다 → 얻어가다, 우려내다","type":"word","src":"Y"},{"id":11836,"vol":2,"day":24,"w":"scrub","m":"문지르다 / 제거하다(불순물을) / 취소하다 / 관목 숲","p":[{"d":"문지르다 / 제거하다(불순물을) / 취소하다","s":["cancel"]}],"s":["cancel"],"r":"[중세 저지 독일어] schrubben(scrub/문지르다) → 세게 문지르다 → 비벼 씻다, 관목숲","type":"word","src":"Y"},{"id":11837,"vol":2,"day":24,"w":"scruffy","m":"지저분한 / 초라한","p":[{"d":"지저분한 / 초라한","s":["shabby"]}],"s":["shabby"],"r":"[scruff(목덜미, 지저분함) + -y] → 꾀죄죄한 → 지저분한, 초라한","type":"word","src":"Y"},{"id":11838,"vol":2,"day":24,"w":"scuffle","m":"맞붙어 싸우다 / 겨우 생계를 꾸려가다 / 난투","p":[{"d":"맞붙어 싸우다 / 겨우 생계를 꾸려가다 / 난투","s":["brawl"]}],"s":["brawl"],"r":"[scuffle, 실랑이] → 맞붙어 다투다 → 맞붙어 싸우다, 겨우 생계를 꾸려가다","type":"word","src":"Y"},{"id":11839,"vol":2,"day":24,"w":"scum","m":"찌꺼기 / 인간 쓰레기","p":[],"s":[],"r":"[중세 네덜란드어] schum(거품) → 위에 뜬 찌끼 → 찌꺼기, 인간 쓰레기","type":"word","src":"Y"},{"id":11840,"vol":2,"day":24,"w":"scurrilous","m":"상스러운 / 악의적인","p":[],"s":[],"r":"scurril(buffoon/익살꾼) + -ous(형용사형) → 상스럽게 놀리는 → 상스러운, 악의적인","type":"word","src":"Y"},{"id":11841,"vol":2,"day":24,"w":"scurry","m":"허둥지둥 달리다 / 서두르다","p":[{"d":"허둥지둥 달리다","s":["scamper"]}],"s":["scamper"],"r":"[중세 영어] scurren(hurry/서두르다) → 종종걸음으로 바쁘게 움직이다 → 급히 가다","type":"word","src":"Y"},{"id":11842,"vol":2,"day":24,"w":"scuttle","m":"황급히 달리다 / 무산시키다 / 가라앉게 하다(배를) / 석탄 통","p":[],"s":[],"r":"[scud(질주하다)의 변형] scuttle → 종종걸음 치다 → 황급히 달리다, 무산시키다, 가라앉게 하다","type":"word","src":"Y"},{"id":11843,"vol":2,"day":24,"w":"sea otter","m":"해달","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"A sea otter floated on its back near the shore.","ko":"해달 한 마리가 해안 근처에서 등을 대고 떠 있었다."}},{"id":11844,"vol":2,"day":24,"w":"seaborne","m":"해상 수송의","p":[],"s":[],"r":"sea(바다) + borne(운반되는) → 바다로 실어 나르는 → 해상 수송의","type":"word","src":"Y"},{"id":11845,"vol":2,"day":24,"w":"seafaring","m":"항해의 / 직업으로 배를 타는","p":[],"s":[],"r":"sea(바다) + faring(다니는) → 바다를 다니는 → 항해의, 직업으로 배를 타는","type":"word","src":"Y"},{"id":11846,"vol":2,"day":24,"w":"seam","m":"솔기 / 갈라진 틈 / 주름살 / 봉합하다","p":[],"s":[],"r":"[고대 영어] seam(stitch/바느질) → 이어 맞추는 솔기 → 솔기, 이음매","type":"word","src":"Y","uf":["해부"]},{"id":11847,"vol":2,"day":24,"w":"seamy","m":"솔기가 있는 / 혐오스런","p":[{"d":"솔기가 있는 / 혐오스런","s":["sordid","base"]}],"s":["sordid","base"],"r":"seam(솔기) + -y(형용사형) → 솔기가 드러난, 뒷면의 → 솔기가 있는, 혐오스런","type":"word","src":"Y"},{"id":11848,"vol":2,"day":24,"w":"secession","m":"탈퇴 / 분리","p":[],"s":[],"r":"se(apart/떨어져) + cess(go/가다) + -ion(명사형) → 떨어져 나감 → 탈퇴, 분리","type":"word","src":"Y"},{"id":11849,"vol":2,"day":24,"w":"second mate","m":"2등 항해사","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The second mate checked the ship's course.","ko":"그 2등 항해사가 배의 항로를 확인했다."}},{"id":11850,"vol":2,"day":24,"w":"sectarian","m":"종파의 / 당파심 강한 / 편협한","p":[{"d":"종파의 / 당파심 강한","s":["partisan"]},{"d":"편협한","s":["parochial"]}],"s":["partisan","parochial"],"r":"sect(ar)(part/분파) + -ian(~에 속한(사람)) → 분파에 속한 → 종파의, 당파심 강한, 편협한","type":"word","src":"Y"},{"id":11851,"vol":2,"day":24,"w":"Security Council","m":"안전 보장 이사회(유엔)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The Security Council voted on the resolution.","ko":"안전 보장 이사회가 그 결의안에 투표했다."}},{"id":11852,"vol":2,"day":24,"w":"seditious","m":"선동적인 / 폭동적인","p":[],"s":[],"r":"sed(it)(apart/떨어져, 반란) + -ious(형용사형) → 선동해 갈라놓는 → 선동적인, 폭동적인","type":"word","src":"Y"},{"id":11853,"vol":2,"day":24,"w":"see how the land lies","m":"형세를 살펴보다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Let's wait and see how the land lies first.","ko":"먼저 형세를 살펴보자."}},{"id":11854,"vol":2,"day":24,"w":"see off","m":"배웅하다 / 물리치다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"We went to the airport to see her off.","ko":"우리는 그녀를 배웅하러 공항에 갔다."}},{"id":11855,"vol":2,"day":24,"w":"see the point","m":"이유를 알다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I don't see the point of arguing anymore.","ko":"나는 더 이상 다투는 이유를 모르겠다."}},{"id":11856,"vol":2,"day":24,"w":"see through","m":"간파하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She saw through his excuse at once.","ko":"그녀는 그의 변명을 즉시 간파했다."}},{"id":11857,"vol":2,"day":24,"w":"seemly","m":"적당한 / 점잖은","p":[{"d":"적당한","s":["appropriate"]},{"d":"점잖은","s":["decorous"]}],"s":["appropriate","decorous"],"r":"seem(어울리다) + -ly(부사형) → 어울리는 → 적당한, 점잖은","type":"word","src":"Y"},{"id":11858,"vol":2,"day":24,"w":"seethe","m":"끓어오르다 / 들끓다","p":[{"d":"끓어오르다","s":["simmer"]}],"s":["simmer"],"r":"[고대 영어] seothan(끓다) → 부글부글 끓다 → 끓어오르다, 들끓다","type":"word","src":"Y"},{"id":11859,"vol":2,"day":24,"w":"self-assured","m":"자신 있는","p":[{"d":"자신 있는","s":["confident"]}],"s":["confident"],"r":"self(자기) + assured(확신하는) → 자기를 확신하는 → 자신 있는","type":"word","src":"Y"},{"id":11860,"vol":2,"day":24,"w":"self-checkout kiosk","m":"무인 계산대","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He paid at the self-checkout kiosk.","ko":"그는 무인 계산대에서 지불했다."}},{"id":11861,"vol":2,"day":24,"w":"self-conceit","m":"자만심 / 자부심","p":[],"s":[],"r":"self(자기) + conceit(자만) → 자기를 높이 봄 → 자만심, 자부심","type":"word","src":"Y"},{"id":11862,"vol":2,"day":24,"w":"self-confident","m":"자신 있는","p":[],"s":[],"r":"self(자기) + confident(확신하는) → 자기를 믿는 → 자신 있는","type":"word","src":"Y"},{"id":11863,"vol":2,"day":24,"w":"self-congratulatory","m":"자축하는","p":[],"s":[],"r":"self(자기) + congratulatory(축하하는) → 자기를 축하하는 → 자축하는","type":"word","src":"Y"},{"id":11864,"vol":2,"day":24,"w":"self-conscious","m":"자기 의식적인 / 남의 시선을 의식하는","p":[],"s":[],"r":"self(자기) + conscious(의식하는) → 자기를 의식하는 → 자기 의식적인, 남의 시선을 의식하는","type":"word","src":"Y"},{"id":11865,"vol":2,"day":24,"w":"self-control","m":"자제력","p":[],"s":[],"r":"self(자기) + control(통제) → 자기를 다스림 → 자제력","type":"word","src":"Y"},{"id":11866,"vol":2,"day":24,"w":"self-defeating","m":"자멸적인 / 문제를 오히려 키우는","p":[],"s":[],"r":"self(자기) + defeating(패배시키는) → 스스로를 무너뜨리는 → 자멸적인","type":"word","src":"Y"},{"id":11867,"vol":2,"day":24,"w":"self-doubt","m":"자기 회의","p":[],"s":[],"r":"self(자기) + doubt(의심) → 자기를 의심함 → 자기 회의","type":"word","src":"Y"},{"id":11868,"vol":2,"day":24,"w":"self-deprecating","m":"자신을 비하하는","p":[],"s":[],"r":"self(자기) + deprecating(깎아내리는) → 자기를 낮추는 → 자신을 비하하는","type":"word","src":"Y"},{"id":11869,"vol":2,"day":24,"w":"self-effacing","m":"자신을 내세우지 않는","p":[],"s":[],"r":"self(자기) + effacing(지우는) → 자기를 지우는 → 자신을 내세우지 않는","type":"word","src":"Y"},{"id":11870,"vol":2,"day":24,"w":"self-employed","m":"자영업의","p":[],"s":[],"r":"self(자기) + employed(고용된) → 스스로를 고용한 → 자영업의","type":"word","src":"Y"},{"id":11871,"vol":2,"day":24,"w":"self-evident","m":"자명한","p":[],"s":[],"r":"self(자기) + evident(분명한) → 그 자체로 분명한 → 자명한","type":"word","src":"Y"},{"id":11872,"vol":2,"day":24,"w":"self-explanatory","m":"자명한","p":[],"s":[],"r":"self(자기) + explanatory(설명하는) → 스스로 설명되는 → 자명한","type":"word","src":"Y"},{"id":11873,"vol":2,"day":24,"w":"self-fulfilling","m":"자기 충족적인","p":[],"s":[],"r":"self(자기) + fulfilling(이루는) → 스스로 이루어지는 → 자기 충족적인","type":"word","src":"Y"},{"id":11874,"vol":2,"day":24,"w":"self-imposed","m":"스스로 부과한 / 자진해서 하는","p":[{"d":"스스로 부과한 / 자진해서 하는","s":["voluntary"]}],"s":["voluntary"],"r":"self(자기) + imposed(부과된