l":2,"day":13,"w":"imposture","m":"사기 / 사칭","p":[{"d":"사기","s":["deceiving"]}],"s":["deceiving"],"r":"im(on/위에) + post(put/놓다) + -ure(명사형) → 남을 속여 앉힘 → 사기, 사칭","type":"word","src":"Y"},{"id":10175,"vol":2,"day":13,"w":"impracticable","m":"실행할 수 없는 / 통행할 수 없는","p":[{"d":"실행할 수 없는","s":["unfeasible"]}],"s":["unfeasible"],"r":"im(not/부정) + practic(able)(실행 가능한) → 실행할 수 없는 → 실행할 수 없는","type":"word","src":"Y"},{"id":10176,"vol":2,"day":13,"w":"impresario","m":"공연 주최자","p":[{"d":"공연 주최자","s":["organizer"]}],"s":["organizer"],"r":"[이탈리아어] impresario(맡아 하는 이) ← impresa(사업) → 공연을 맡은 이 → 공연 주최자","type":"word","src":"Y"},{"id":10177,"vol":2,"day":13,"w":"imprimatur","m":"출판 허가 / 인가","p":[{"d":"출판 허가 / 인가","s":["approval"]}],"s":["approval"],"r":"im(강조) + prim(print/찍다) + -atur(어형 변화) → 찍어도 좋다는 허가 → 출판 허가, 인가","type":"word","src":"Y"},{"id":10178,"vol":2,"day":13,"w":"impropriety","m":"부적절한 언행 / 부정확한 표현","p":[{"d":"부적절한 언행","s":["indecency"]}],"s":["indecency"],"r":"im(not/부정) + propri(proper/적절한) + -ety(형용사형) → 적절하지 못함 → 부적절한 언행","type":"word","src":"Y"},{"id":10179,"vol":2,"day":13,"w":"in a jam","m":"곤경에 빠져","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He was in a jam after missing his flight.","ko":"그는 비행기를 놓쳐서 곤경에 빠졌다."}},{"id":10180,"vol":2,"day":13,"w":"in a muddle","m":"당황하여","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Her thoughts were in a muddle after the news.","ko":"그 소식 후 그녀의 생각은 당황하여 뒤엉켰다."}},{"id":10181,"vol":2,"day":13,"w":"in all","m":"합계하여 / 모두 합쳐","p":[{"d":"합계하여 / 모두 합쳐","s":["altogether"]}],"s":["altogether"],"r":"","type":"phrase","src":"Y","ex":{"en":"There were fifty guests in all.","ko":"손님이 모두 합쳐 오십 명이었다."}},{"id":10182,"vol":2,"day":13,"w":"in any case","m":"어떤 경우라도 / 여하튼","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In any case, we should leave early.","ko":"여하튼 우리는 일찍 떠나야 한다."}},{"id":10183,"vol":2,"day":13,"w":"in behalf of","m":"~의 이익을 위해","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She spoke in behalf of the workers.","ko":"그녀는 노동자들의 이익을 위해 말했다."}},{"id":10184,"vol":2,"day":13,"w":"in cahoots with","m":"~와 협력하여","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The two firms were in cahoots to fix prices.","ko":"그 두 회사는 가격을 조작하려고 협력했다."}},{"id":10185,"vol":2,"day":13,"w":"in case of","m":"~의 경우에는 / ~을 대비해","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In case of fire, use the stairs.","ko":"화재의 경우에는 계단을 이용해라."}},{"id":10186,"vol":2,"day":13,"w":"in compliance with","m":"~에 따라","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The work was done in compliance with the rules.","ko":"그 작업은 규칙에 따라 이루어졌다."}},{"id":10187,"vol":2,"day":13,"w":"in connection with","m":"~와 관련하여","p":[{"d":"~와 관련하여","s":["in relation to"]}],"s":["in relation to"],"r":"","type":"phrase","src":"Y","ex":{"en":"Police questioned him in connection with the theft.","ko":"경찰은 그 절도와 관련하여 그를 심문했다."}},{"id":10188,"vol":2,"day":13,"w":"in contradistinction to","m":"~와 대조적으로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In contradistinction to her sister, she is shy.","ko":"언니와 대조적으로 그녀는 수줍다."}},{"id":10189,"vol":2,"day":13,"w":"in droves","m":"떼를 지어","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Tourists came in droves to the festival.","ko":"관광객들이 떼를 지어 그 축제에 왔다."}},{"id":10190,"vol":2,"day":13,"w":"in due course = in due time","m":"적절한 때가 되면 / 머지않아","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The results will come in due course.","ko":"그 결과는 머지않아 나올 것이다."}},{"id":10191,"vol":2,"day":13,"w":"in good order","m":"순조롭게 / 무사히","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The event went off in good order.","ko":"그 행사는 순조롭게 진행되었다."}},{"id":10192,"vol":2,"day":13,"w":"in hand","m":"갖고 있는 / 고려하고 있는 / 진행 중인","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The matter in hand needs our full attention.","ko":"진행 중인 그 문제는 우리의 온전한 주의가 필요하다."}},{"id":10193,"vol":2,"day":13,"w":"in lieu of","m":"~대신에","p":[{"d":"~대신에","s":["instead of"]}],"s":["instead of"],"r":"","type":"phrase","src":"Y","ex":{"en":"She used honey in lieu of sugar.","ko":"그녀는 설탕 대신에 꿀을 썼다."}},{"id":10194,"vol":2,"day":13,"w":"in light of","m":"~에 비추어","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In light of the new facts, we changed the plan.","ko":"새로운 사실에 비추어 우리는 계획을 바꿨다."}},{"id":10195,"vol":2,"day":13,"w":"in medias res","m":"거두절미하고 / 사건 도중에서","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The story begins in medias res, in the middle of battle.","ko":"그 이야기는 거두절미하고 전투 도중에서 시작한다."}},{"id":10196,"vol":2,"day":13,"w":"in one's own right","m":"스스로의 능력으로 / 자기의 권리로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She is a famous scientist in her own right.","ko":"그녀는 스스로의 능력으로 유명한 과학자다."}},{"id":10197,"vol":2,"day":13,"w":"in over one's head","m":"자기 능력을 넘어서는 일에 얽힌","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He was in over his head with the new job.","ko":"그는 새 일이 자기 능력을 넘어서서 힘겨웠다."}},{"id":10198,"vol":2,"day":13,"w":"in private","m":"사생활에서 / 은밀히 / 비공개로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Let's discuss this in private.","ko":"이것을 은밀히 논의하자."}},{"id":10199,"vol":2,"day":13,"w":"in regard to","m":"~에 관해서 / ~과 관련하여","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In regard to your request, we need more time.","ko":"당신의 요청에 관해서 우리는 시간이 더 필요하다."}},{"id":10200,"vol":2,"day":13,"w":"in response to","m":"~에 응하여 / ~에 답하여","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In response to the demand, they lowered prices.","ko":"그 요구에 응하여 그들은 가격을 내렸다."}},{"id":10201,"vol":2,"day":13,"w":"in round numbers","m":"대략","p":[{"d":"대략","s":["roughly"]}],"s":["roughly"],"r":"","type":"phrase","src":"Y","ex":{"en":"In round numbers, the cost is a thousand dollars.","ko":"대략 그 비용은 천 달러다."}},{"id":10202,"vol":2,"day":13,"w":"in shape","m":"건강한","p":[{"d":"건강한","s":["healthy","fit"]}],"s":["healthy","fit"],"r":"","type":"phrase","src":"Y","ex":{"en":"She stays in shape by running daily.","ko":"그녀는 매일 달려서 건강을 유지한다."}},{"id":10203,"vol":2,"day":13,"w":"in store","m":"준비하여 / 일어나려 하는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"A surprise was in store for him.","ko":"그를 위한 놀라움이 준비되어 있었다."}},{"id":10204,"vol":2,"day":13,"w":"in sync","m":"일치하는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The dancers moved in sync.","ko":"그 무용수들은 일치하여 움직였다."}},{"id":10205,"vol":2,"day":13,"w":"in the bag","m":"확실하여(성공이)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"With a big lead, the win was in the bag.","ko":"큰 점수 차로 승리는 확실했다."}},{"id":10206,"vol":2,"day":13,"w":"in the broad light of day","m":"대낮에","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The theft happened in the broad light of day.","ko":"그 절도는 대낮에 일어났다."}},{"id":10207,"vol":2,"day":13,"w":"in the distance","m":"먼 곳에 / 멀리서","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"We saw mountains in the distance.","ko":"우리는 먼 곳에서 산을 봤다."}},{"id":10208,"vol":2,"day":13,"w":"in the event of","m":"만약 ~할 경우","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In the event of rain, the game is canceled.","ko":"비가 올 경우 경기는 취소된다."}},{"id":10209,"vol":2,"day":13,"w":"in the first place","m":"첫째로 / 우선","p":[{"d":"첫째로 / 우선","s":["to begin with"]}],"s":["to begin with"],"r":"","type":"phrase","src":"Y","ex":{"en":"In the first place, the plan is too costly.","ko":"첫째로 그 계획은 비용이 너무 많이 든다."}},{"id":10210,"vol":2,"day":13,"w":"in the hole","m":"빚을 진","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"After the trip, they were deep in the hole.","ko":"그 여행 후 그들은 빚을 많이 졌다."}},{"id":10211,"vol":2,"day":13,"w":"in the middle of","m":"~의 한가운데에","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She stood in the middle of the room.","ko":"그녀는 방 한가운데에 섰다."}},{"id":10212,"vol":2,"day":13,"w":"in the nature of","m":"~와 비슷한","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"His remark was in the nature of a warning.","ko":"그의 말은 경고와 비슷했다."}},{"id":10213,"vol":2,"day":13,"w":"in the presence of","m":"~의 앞에서 / ~의 면전에서","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He signed the paper in the presence of a lawyer.","ko":"그는 변호사의 면전에서 그 서류에 서명했다."}},{"id":10214,"vol":2,"day":13,"w":"in the red","m":"적자를 내는","p":[{"d":"적자를 내는","s":["in debt"]}],"s":["in debt"],"r":"","type":"phrase","src":"Y","ex":{"en":"The company has been in the red for two years.","ko":"그 회사는 2년째 적자를 내고 있다."}},{"id":10215,"vol":2,"day":13,"w":"in utero","m":"태내에 있는","p":[{"d":"태내에 있는","s":["unborn"]}],"s":["unborn"],"r":"","type":"phrase","src":"Y","ex":{"en":"The baby's health was checked in utero.","ko":"그 아기의 건강은 태내에서 확인되었다."}},{"id":10216,"vol":2,"day":13,"w":"in vivo","m":"체내에서 진행되는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The drug was tested in vivo before approval.","ko":"그 약은 승인 전에 체내에서 시험되었다."}},{"id":10217,"vol":2,"day":13,"w":"in your dreams","m":"꿈 깨(놀고 있네)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"\"You'll win the lottery?\" \"In your dreams!\"","ko":"\"복권에 당첨될 거라고?\" \"꿈 깨!\""}}]