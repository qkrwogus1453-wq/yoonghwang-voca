"]}],"s":["whopping"],"r":"[huge + monstrous 혼성] humongous → 어마어마하게 큰 → 거대한, 터무니없이 큰","type":"word","src":"Y"},{"id":10111,"vol":2,"day":13,"w":"humpback","m":"곱사등이 / 혹등고래","p":[{"d":"곱사등이","s":["hunchback"]}],"s":["hunchback"],"r":"hump(혹) + back(등) → 등에 혹이 있는 → 곱사등이, 혹등고래","type":"word","src":"Y"},{"id":10112,"vol":2,"day":13,"w":"humus","m":"부식토 / 부식질","p":[{"d":"부식토 / 부식질","s":["decomposed organic matter"]}],"s":["decomposed organic matter"],"r":"[라틴어] humus(흙) → 썩어 흙이 된 것 → 부식토, 부식질","type":"word","src":"Y"},{"id":10113,"vol":2,"day":13,"w":"hung parliament","m":"절대 다수당이 없는 의회","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The election produced a hung parliament.","ko":"그 선거는 절대 다수당이 없는 의회를 만들어냈다."}},{"id":10114,"vol":2,"day":13,"w":"hunk","m":"큰 덩어리 / 섹시한 남자","p":[],"s":[],"r":"[중세 영어] hunk(큰 덩어리) → 큼직한 덩이 → 큰 덩어리, 섹시한 남자","type":"word","src":"Y"},{"id":10115,"vol":2,"day":13,"w":"hurl","m":"세게 내던지다 / 욕설을 퍼붓다 [at]","p":[],"s":[],"r":"[중세 영어] hurlen(hurl/던지다) → 세게 던지다 → 집어던지다, 퍼붓다","type":"word","src":"Y","pp":["at"]},{"id":10116,"vol":2,"day":13,"w":"hurtle","m":"돌진하다","p":[{"d":"돌진하다","s":["rush","dash"]}],"s":["rush","dash"],"r":"[hurt(부딪치다)의 반복형] hurtle → 세차게 부딪치며 나아가다 → 돌진하다","type":"word","src":"Y"},{"id":10117,"vol":2,"day":13,"w":"husk","m":"껍질","p":[{"d":"껍질","s":["hull"]}],"s":["hull"],"r":"[중세 네덜란드어] hulsche(껍질) → 겉을 싼 것 → 껍질","type":"word","src":"Y"},{"id":10118,"vol":2,"day":13,"w":"hydraulic","m":"수력학의","p":[],"s":[],"r":"hydr(a)(water/물) + -ulic(형용사형) → 물의 힘에 관한 → 수력학의","type":"word","src":"Y"},{"id":10119,"vol":2,"day":13,"w":"hydrophobia","m":"공수병 / 광견병","p":[{"d":"공수병 / 광견병","s":["rabies"]}],"s":["rabies"],"r":"hydro(water/물) + phob(fear/공포) + -ia(명사형(상태)) → 물에 대한 공포 → 공수병, 광견병","type":"word","src":"Y"},{"id":10120,"vol":2,"day":13,"w":"hymn","m":"찬송가 / 찬가","p":[{"d":"찬송가","s":["psalm"]}],"s":["psalm"],"r":"[그리스어] hymnos(song of praise/찬양의 노래) → 찬양하는 노래 → 찬송가","type":"word","src":"Y"},{"id":10121,"vol":2,"day":13,"w":"hyperactive"