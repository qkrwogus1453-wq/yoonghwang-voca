[{"id":10050,"vol":2,"day":13,"w":"hit pause","m":"일시 정지하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Let's hit pause and think this over.","ko":"잠시 멈추고 이것을 곰곰이 생각해 보자."}},{"id":10051,"vol":2,"day":13,"w":"hit rock bottom","m":"바닥을 치다 / 바닥으로 떨어지다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"His confidence hit rock bottom after the loss.","ko":"그의 자신감은 그 패배 후 바닥을 쳤다."}},{"id":10052,"vol":2,"day":13,"w":"hit the ball out of the park","m":"대성공을 거두다 / 장외 홈런을 치다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Her new book hit the ball out of the park.","ko":"그녀의 새 책은 대성공을 거뒀다."}},{"id":10053,"vol":2,"day":13,"w":"hit the books","m":"열심히 공부하다","p":[{"d":"열심히 공부하다","s":["study hard"]}],"s":["study hard"],"r":"","type":"phrase","src":"Y","ex":{"en":"I need to hit the books before the exam.","ko":"나는 시험 전에 열심히 공부해야 한다."}},{"id":10054,"vol":2,"day":13,"w":"hit the bottle","m":"과음하다","p":[{"d":"과음하다","s":["drink too much alcohol"]}],"s":["drink too much alcohol"],"r":"","type":"phrase","src":"Y","ex":{"en":"He started hitting the bottle after the divorce.","ko":"그는 이혼 후 과음하기 시작했다."}},{"id":10055,"vol":2,"day":13,"w":"hit the spot","m":"더할 나위 없다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"A cold drink really hit the spot.","ko":"차가운 음료가 정말 더할 나위 없었다."}},{"id":10056,"vol":2,"day":13,"w":"hive","m":"벌통 / 붐비는 곳 / 군중","p":[],"s":[],"r":"[고대 영어] hyf(hive/벌통) → 벌들이 사는 통 → 벌통, 중심지","type":"word","src":"Y"},{"id":10057,"vol":2,"day":13,"w":"hoary","m":"백발의 / 진부한","p":[{"d":"백발의","s":["grey-haired"]},{"d":"진부한","s":["hackneyed"]}],"s":["grey-haired","hackneyed"],"r":"[고대 영어] har(grey/회색) → 오래되어 회백색이 된 → 백발의, 낡은","type":"word","src":"Y"},{"id":10058,"vol":2,"day":13,"w":"hobnob","m":"환담","p":[],"s":[],"r":"[hob(시골뜨기) + nob(귀족)에서, 어울려 마심] hobnob → 격의 없이 어울리다 → 환담","type":"word","src":"Y"},{"id":10059,"vol":2,"day":13,"w":"hodgepodge","m":"뒤범벅 / 잡탕","p":[{"d":"뒤범벅","s":["hotchpotch","jumble"]}],"s":["hotchpotch","jumble"],"r":"[ho