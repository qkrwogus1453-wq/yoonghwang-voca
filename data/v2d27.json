[{"id":12307,"vol":2,"day":27,"w":"take a career break","m":"휴직하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She took a career break to raise her kids.","ko":"그녀는 아이들을 키우려고 휴직했다."}},{"id":12308,"vol":2,"day":27,"w":"take a load off","m":"편히 쉬다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Come in and take a load off.","ko":"들어와서 편히 쉬어라."}},{"id":12309,"vol":2,"day":27,"w":"take a page from","m":"모방하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The rival firm took a page from our strategy.","ko":"그 경쟁사는 우리 전략을 모방했다."}},{"id":12310,"vol":2,"day":27,"w":"take a rain-check","m":"뒤로 미루다 / 다음을 기약하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I'll take a rain-check on dinner tonight.","ko":"오늘 밤 저녁은 다음으로 미룰게."}},{"id":12311,"vol":2,"day":27,"w":"take a sip","m":"조금씩 마시다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She took a sip of the hot tea.","ko":"그녀는 뜨거운 차를 조금씩 마셨다."}},{"id":12312,"vol":2,"day":27,"w":"take a stand","m":"태도를 취하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"It's time to take a stand on the issue.","ko":"그 문제에 태도를 취할 때다."}},{"id":12313,"vol":2,"day":27,"w":"take action","m":"행동을 취하다 / 조치를 취하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The city took action to reduce pollution.","ko":"그 시는 오염을 줄이려고 조치를 취했다."}},{"id":12314,"vol":2,"day":27,"w":"take ~ by storm","m":"사로잡다 / ~에서 대성공을 거두다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The new band took the country by storm.","ko":"그 새 밴드는 그 나라에서 대성공을 거뒀다."}},{"id":12315,"vol":2,"day":27,"w":"take ~ by surprise","m":"불시에 덮치다 / 깜짝 놀라게 하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The sudden storm took us by surprise.","ko":"그 갑작스러운 폭풍이 우리를 깜짝 놀라게 했다."}},{"id":12316,"vol":2,"day":27,"w":"take classes","m":"수업을 듣다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She takes classes in the evening.","ko":"그녀는 저녁에 수업을 듣는다."}},{"id":12317,"vol":2,"day":27,"w":"take A for B","m":"A를 B로 잘못 알다","p":[{"d":"A를 B로 잘못 알다","s":["mistake A for B"]}],"s":["mistake A for B"],"r":"","type":"phrase","src":"Y","ex":{"en":"In the dark, I took him for his brother.","ko":"어둠 속에서 나는 그를 그의 형으로 잘못 알았다."}},{"id":12318,"vol":2,"day":27,"w":"take ~ for a ride","m":"~를 속이다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The dishonest dealer took us for a ride.","ko":"그 부정직한 상인이 우리를 속였다."}},{"id":12319,"vol":2,"day":27,"w":"take hold","m":"확립되다 / 정착되다 / 장악하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The new custom soon took hold.","ko":"그 새 관습은 곧 정착되었다."}},{"id":12320,"vol":2,"day":27,"w":"take ~ into custody","m":"~를 구금시키다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Police took the suspect into custody.","ko":"경찰이 그 용의자를 구금했다."}},{"id":12321,"vol":2,"day":27,"w":"take it easy","m":"편히 쉬다 / 마음을 편히 갖다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Take it easy this weekend and rest.","ko":"이번 주말에는 편히 쉬어라."}},{"id":12322,"vol":2,"day":27,"w":"take it on the chin","m":"묵묵히 받아들이다(힘들거나 불쾌한 상황을)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He took the bad news on the chin.","ko":"그는 그 나쁜 소식을 묵묵히 받아들였다."}},{"id":12323,"vol":2,"day":27,"w":"take it upon oneself to do","m":"~할 책임을 떠맡다 / ~하겠다고 자신이 결정하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She took it upon herself to fix the problem.","ko":"그녀는 그 문제를 해결할 책임을 떠맡았다."}},{"id":12324,"vol":2,"day":27,"w":"take it out of","m":"~를 지치게 하다 / ~에게 분풀이를 하다","p":[{"d":"~를 지치게 하다","s":["exhaust"]}],"s":["exhaust"],"r":"","type":"phrase","src":"Y","ex":{"en":"The long trip really took it out of me.","ko":"그 긴 여행이 정말 나를 지치게 했다."}},{"id":12325,"vol":2,"day":27,"w":"take it out on","m":"~에게 분풀이를 하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Don't take it out on the kids.","ko":"아이들에게 분풀이하지 마라."}},{"id":12326,"vol":2,"day":27,"w":"take offense","m":"화내다","p":[{"d":"화내다","s":["be annoyed"]}],"s":["be annoyed"],"r":"","type":"phrase","src":"Y","ex":{"en":"She took offense at his careless joke.","ko":"그녀는 그의 무심한 농담에 화를 냈다."}},{"id":12327,"vol":2,"day":27,"w":"take one's place","m":"자리 잡다 / 존재를 인정받다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The new theory took its place among the classics.","ko":"그 새 이론은 고전들 사이에서 존재를 인정받았다."}},{"id":12328,"vol":2,"day":27,"w":"take pride in","m":"~을 자랑하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He takes pride in his work.","ko":"그는 자신의 일을 자랑스러워한다."}},{"id":12329,"vol":2,"day":27,"w":"take ~ up on","m":"받아들이다(제의를)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I'll take you up on that offer.","ko":"그 제의를 받아들일게."}},{"id":12330,"vol":2,"day":27,"w":"take the bitter with the sweet","m":"고락(苦樂)을 함께 받아들이다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"In life, you must take the bitter with the sweet.","ko":"인생에서 너는 고락을 함께 받아들여야 한다."}},{"id":12331,"vol":2,"day":27,"w":"take the fifth","m":"묵비권을 행사하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The witness chose to take the fifth.","ko":"그 증인은 묵비권을 행사하기로 했다."}},{"id":12332,"vol":2,"day":27,"w":"take the gilt off the gingerbread","m":"매력을 반감시키다 / 흥을 깨다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The long wait took the gilt off the gingerbread.","ko":"그 긴 기다림이 흥을 깼다."}},{"id":12333,"vol":2,"day":27,"w":"take the lead","m":"선두에 서다 / 주도권을 잡다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Our runner took the lead in the last lap.","ko":"우리 주자가 마지막 바퀴에서 선두에 섰다."}},{"id":12334,"vol":2,"day":27,"w":"take the plunge","m":"뛰어들다 / 생소한 일을 단행하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"After years of dating, they took the plunge and married.","ko":"여러 해 사귄 후 그들은 큰맘 먹고 결혼했다."}},{"id":12335,"vol":2,"day":27,"w":"take the trouble to do","m":"수고스럽게 ~을 하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She took the trouble to write a thank-you note.","ko":"그녀는 수고스럽게 감사 편지를 썼다."}},{"id":12336,"vo