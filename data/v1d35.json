[{"id":4460,"vol":1,"day":35,"w":"long past","m":"~이 한참 지난","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"It was long past midnight when he got home.","ko":"그가 집에 왔을 때는 자정이 한참 지나 있었다."}},{"id":4461,"vol":1,"day":35,"w":"longevity","m":"장수 / 수명","p":[],"s":[],"r":"long(long/긴) + ev(age/시대) + -ity(명사형) → 오래 사는 것 → 장수","type":"word","src":"Y"},{"id":4462,"vol":1,"day":35,"w":"long-held","m":"오래 간직해 온","p":[],"s":[],"r":"long(오랜) + held(간직한) → 오래 지녀 온 → 오래 간직해 온","type":"word","src":"Y"},{"id":4463,"vol":1,"day":35,"w":"long-term","m":"장기적인","p":[],"s":[],"r":"long(긴) + term(기간) → 긴 기간의 → 장기적인","type":"word","src":"Y"},{"id":4464,"vol":1,"day":35,"w":"look after","m":"보살펴 주다 / ~에 주의하다","p":[{"d":"보살펴 주다","s":["take care of"]}],"s":["take care of"],"r":"","type":"phrase","src":"Y","ex":{"en":"She looks after her younger brother after school.","ko":"그녀는 방과 후 남동생을 보살핀다."}},{"id":4465,"vol":1,"day":35,"w":"look around","m":"둘러보다 / 구경하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"We looked around the museum for an hour.","ko":"우리는 한 시간 동안 박물관을 둘러봤다."}},{"id":4466,"vol":1,"day":35,"w":"Look before you leap.","m":"돌다리도 두드려 보고 건너라.","p":[],"s":[],"r":"","type":"phrase","src":"Y"},{"id":4467,"vol":1,"day":35,"w":"look down on","m":"경멸하다","p":[{"d":"경멸하다","s":["despise","scorn"]}],"s":["despise","scorn"],"r":"","type":"phrase","src":"Y","ex":{"en":"Don't look down on people who have less.","ko":"가진 것이 적은 사람들을 경멸하지 마라."}},{"id":4468,"vol":1,"day":35,"w":"look for","m":"찾다 / 기대하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I'm looking for my missing keys.","ko":"나는 잃어버린 열쇠를 찾고 있다."}},{"id":4469,"vol":1,"day":35,"w":"look forward to","m":"기대하다","p":[{"d":"기대하다","s":["expect","anticipate"]}],"s":["expect","anticipate"],"r":"","type":"phrase","src":"Y","ex":{"en":"I look forward to seeing you again.","ko":"너를 다시 만나기를 기대한다."}},{"id":4470,"vol":1,"day":35,"w":"look high and low","m":"샅샅이 찾다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex"