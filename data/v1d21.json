ant","excessive"],"r":"extra(beyond) + vag(wander/방랑하다) + -ant → 범위를 벗어나 방랑하는 → 낭비하는, 과장된","rel":"extravagance 사치, 낭비(=wastefulness)","type":"word","src":"Y"},{"id":2637,"vol":1,"day":21,"w":"extremely","m":"극도로 / 아주","s":["very"],"r":"","rel":"extreme 극단적인, 극심한; 극단; extremist 극단적인; 과격주의자","type":"word","src":"Y"},{"id":2638,"vol":1,"day":21,"w":"extricate","m":"구출해내다 / 탈출시키다","s":["remove","free","liberate","rescue"],"r":"ex(out) + tric(entangle/얽히다) + -ate → 얽힌 것을 풀어내다 → 구출하다, 탈출시키다","rel":"extrication 구출","type":"word","src":"Y"},{"id":2639,"vol":1,"day":21,"w":"extrinsic","m":"관계없는 / 비본질적인 / 외부의","s":["extraneous","external","exterior"],"r":"extrin(outside/바깥) + -sic → 바깥에서 온 → 고유하지 않은, 외부의","rel":"","type":"word","src":"Y"},{"id":2640,"vol":1,"day":21,"w":"extrovert","m":"외향적인 / 외향적인 사람","s":["outgoing","gregarious","sociable"],"r":"extra(outside/바깥) + vert(turn/돌리다) → 바깥으로 돌리는 → 외향적인 사람","rel":"extroversion 외향성","type":"word","src":"Y"},{"id":2641,"vol":1,"day":21,"w":"exuberant","m":"열광적인 / 풍부한 / 화려한 / 활기찬","s":["enthusiastic","ebullient","exhilarated","animated","passionate ② 무성한","우거진","lush","luxuriant ③ (부·상상력·재능 등이) 풍부한","(문체가) 화려한"],"r":"ex(out) + uber(fertile/비옥한) + -ant → 비옥하게 넘쳐나는 → 열광적인, 활기가 넘치는","rel":"exuberance 열광, 풍부","type":"word","src":"Y"},{"id":2642,"vol":1,"day":21,"w":"exude","m":"배어나오다 / 풍기다","s":["ooze","seep","emanate","emit","radiate"],"r":"ex(out) + ud(sweat/땀 흘리다) → 밖으로 스며 나오다 → 흘리다, 스며나오다","rel":"","type":"word","src":"Y"},{"id":2643,"vol":1,"day":21,"w":"exult","m":"크게 기뻐하다 / 이겨서 뽐내다","s":["be on cloud nine","jubilate","rejoice"],"r":"ex(out) + ult(leap/뛰다) → 기쁨으로 뛰어오르다 → 기뻐 날뛰다","rel":"exultant 의기양양한(=triumphant); exultation 기뻐 날뜀","type":"word","src":"Y"},{"id":2644,"vol":1,"day":21,"w":"eye","m":"눈여겨보다","s":["watch closely"],"r":"","rel":"","type":"word","src":"Y"},{"id":2645,"vol":1,"day":21,"w":"fable","m":"우화","s":["short moral story","parable","allegory","legend","myth","fiction","lie"],"r":"fa(speak/말하다) + -ble → 말로 전해지는 이야