 of"],"r":"","type":"phrase","src":"Y","ex":{"en":"The sailors were at the mercy of the storm.","ko":"선원들은 폭풍에 좌우되었다."}},{"id":498,"vol":1,"day":5,"w":"at the risk of","m":"~의 위험을 무릅쓰고","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He told the truth at the risk of losing his job.","ko":"그는 직장을 잃을 위험을 무릅쓰고 진실을 말했다."}},{"id":499,"vol":1,"day":5,"w":"at the same time","m":"동시에","p":[{"d":"동시에","s":["simultaneously"]}],"s":["simultaneously"],"r":"","type":"phrase","src":"Y","ex":{"en":"She was reading and listening to music at the same time.","ko":"그녀는 동시에 책을 읽고 음악을 들었다."}},{"id":500,"vol":1,"day":5,"w":"at the top of one's lungs","m":"큰 소리로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The child shouted at the top of his lungs.","ko":"그 아이는 큰 소리로 외쳤다."}},{"id":501,"vol":1,"day":5,"w":"at work","m":"영향을 주는 / 작업 중인 / 작동 중인","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Several factors are at work in this problem.","ko":"이 문제에는 여러 요인이 영향을 주고 있다."}},{"id":502,"vol":1,"day":5,"w":"at year's end","m":"연말에","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The company reviews its budget at year's end.","ko":"그 회사는 연말에 예산을 검토한다."}},{"id":503,"vol":1,"day":5,"w":"atheism","m":"무신론 / 불신앙","p":[{"d":"무신론 / 불신앙","s":["unbelief"]}],"s":["unbelief"],"r":"a(not) + the(god/신) + -ism(주의) → 신이 없다는 주의 → 무신론","type":"word","src":"Y"},{"id":504,"vol":1,"day":5,"w":"athletic","m":"운동 선수다운 / 몸매가 탄탄한","p":[],"s":[],"r":"[그리스어] athlon(prize/상) + -etic(형용사형) → 상을 놓고 겨루는 사람 같은 → 운동 선수다운","type":"word","src":"Y"},{"id":505,"vol":1,"day":5,"w":"atmosphere","m":"공기 / 대기 / 분위기","p":[{"d":"공기 / 대기 / 분위기","s":["ambiance"]}],"s":["ambiance"],"r":"[그리스어] atmos(vapor/증기) + sphere(구체) → 지구를 감싼 증기층 → 대기, 공기, 분위기","type":"word","src":"Y"},{"id":506,"vol":1,"day":5,"w":"atone","m":"속죄하다 / 보상하다 [for]","p":[{"d":"속죄하다","s":["expiate"]},{"d":"보상하다","s":["make amends"]}],"s":["expiate","make amends"],"r":"at(to/~쪽으로) + one(one/하나) → 하나가 되게 화해시키다 → 속죄하다, 벌충하다","typ