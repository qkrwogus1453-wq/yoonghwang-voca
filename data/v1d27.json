":["torment"],"r":"[고대 영어] hearge(써레) → 써레로 갈아엎다 → 써레질하다 / 마음을 긁다 → 괴롭히다","type":"word","src":"Y"},{"id":3378,"vol":1,"day":27,"w":"harry","m":"괴롭히다 / 약탈하다","p":[{"d":"괴롭히다","s":["badger"]},{"d":"약탈하다","s":["plunder","pillage","despoil"]}],"s":["badger","plunder","pillage","despoil"],"r":"[고대 영어] hergian(harry/약탈하다) → 약탈하며 괴롭히다 → 괴롭히다, 약탈하다","type":"word","src":"Y"},{"id":3379,"vol":1,"day":27,"w":"harsh","m":"가혹한 / 거친","p":[{"d":"가혹한","s":["cruel"]}],"s":["cruel"],"r":"[고대 노르드어] harskr(rough/거친) → 거칠고 가혹한 → 모진, 황량한","type":"word","src":"Y"},{"id":3380,"vol":1,"day":27,"w":"harvest","m":"수확하다 / 얻다 / 수확기 / 수확량","p":[{"d":"수확하다","s":["pick"]}],"s":["pick"],"r":"[고대 영어] hærfest(autumn/가을) → 가을에 곡식을 거두어들이다 → 수확, 추수","type":"word","src":"Y"},{"id":3381,"vol":1,"day":27,"w":"hasten","m":"서두르다 / 촉진하다","p":[{"d":"서두르다 / 촉진하다","s":["accelerate"]}],"s":["accelerate"],"r":"haste(haste/서두름) + -en(동사형) → 서두르게 만들다 → 서두르다, 재촉하다","type":"word","src":"Y"},{"id":3382,"vol":1,"day":27,"w":"hasty","m":"성급한","p":[{"d":"성급한","s":["impetuous","precipitate"]}],"s":["impetuous","precipitate"],"r":"haste(서두름) + -y(형용사형) → 서두르는 → 성급한","type":"word","src":"Y"},{"id":3383,"vol":1,"day":27,"w":"hatch","m":"까다(알을) / 부화하다 / 꾸미다(음모를) / 승강구","p":[{"d":"까다(알을) / 부화하다 / 꾸미다(음모를)","s":["contrive"]}],"s":["contrive"],"r":"[고대 영어] haeccan(hatch/부화하다) → 알을 까다 → 부화하다, (음모를) 꾸미다","type":"word","src":"Y"},{"id":3384,"vol":1,"day":27,"w":"hatchet","m":"도끼","p":[],"s":[],"r":"[고대 프랑스어] hachette(작은 도끼) ← hache(도끼) → 손도끼 → 도끼","type":"word","src":"Y"},{"id":3385,"vol":1,"day":27,"w":"hate crime","m":"증오 범죄(다른 종교·인종에 대한)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The attack was investigated as a hate crime.","ko":"그 공격은 증오 범죄로 조사되었다."}},{"id":3386,"vol":1,"day":27,"w":"haughtiness","m":"거만함","p":[{"d":"거만함","s":["arrogance","pomposity","pretentiousness","insolence"]}],"s":["arrogance","pomposity","pretentiousness","insolence"],"r":"haught(high/높은) + -i(어형 변화) + -ness(명사형) → 저를 높이는 태도 → 거만함","type":"word","src":"Y"},{"id":3387,"vol":1,"day":27,"w":"haul","m":"끌어당기다 / 운반하다 / 운반 / 어획량 / 소득 / 획득물","p":[{"d":"끌어당기다","s":["pull"]},{"d":"운반하다 / 운반 / 어획량 / 소득","s":["gain"]}],"s":["pull","gain"],"r":"[중세 영어] halen(pull/당기다) → 세게 당기다 → 잡아끌다, 운반하다","type":"word","src":"Y"},{"id":3388,"vol":1,"day":27,"w":"haunt","m":"출몰하다(유령이) / 머리에서 떠나지 않다 / 자주 드나들다","p":[{"d":"출몰하다(유령이) / 머리에서 떠나지 않다","s":["obsess"]},{"d":"자주 드나들다","s":["frequent"]}],"s":["obsess","frequent"],"r":"[고대 프랑스어] hanter(frequent/자주 다니다) → 계속 따라다니다 → 늘 붙어 따라다니다, 출몰하다","type":"word","src":"Y"},{"id":3389,"vol":1,"day":27,"w":"hauteur","m":"거만함","p":[{"d":"거만함","s":["arrogance"]}],"s":["arrogance"],"r":"[프랑스어] haut(high/높은) + -eur(어형 변화) → 높은 데서 내려다보는 태도 → 오만, 거만한 태도","type":"word","src":"Y"},{"id":3390,"vol":1,"day":27,"w":"have a bee in one's bonnet","m":"골몰해 있다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She has a bee in her bonnet about recycling.","ko":"그녀는 재활용에 골몰해 있다."}},{"id":3391,"vol":1,"day":27,"w":"have a crush on","m":"~에게 홀딱 반하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He has a crush on the new classmate.","ko":"그는 새 반 친구에게 홀딱 반했다."}},{"id":3392,"vol":1,"day":27,"w":"have a go at","m":"~을 시도해보다","p":[{"d":"~을 시도해보다","s":["attempt"]}],"s":["attempt"],"r":"","type":"phrase","src":"Y","ex":{"en":"Why don't you have a go at solving it yourself?","ko":"네가 직접 그것을 풀어 보는 게 어때?"}},{"id":3393,"vol":1,"day":27,"w":"have a long run","m":"장기 흥행하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The musical had a long run on Broadway.","ko":"그 뮤지컬은 브로드웨이에서 장기 흥행했다."}},{"id":3394,"vol":1,"day":27,"w":"have a reluctance to do","m":"~하기를 꺼리다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She had a reluctance to speak in public.","ko":"그녀는 사람들 앞에서 말하기를 꺼렸다."}},{"id":3395,"vol":1,"day":27,"w":"have a say","m":"참견할 권리가 있다 / 발언권이 있다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Every member should have a say in the decision.","ko":"모든 회원은 그 결정