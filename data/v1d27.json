[{"id":3359,"vol":1,"day":27,"w":"hangover","m":"잔존물 / 숙취","p":[{"d":"잔존물","s":["surviving trace"]}],"s":["surviving trace"],"r":"hang(hang/매달리다) + over(over/넘어) → 넘어와 매달려 남은 것 → 잔존물, 숙취","type":"word","src":"Y"},{"id":3360,"vol":1,"day":27,"w":"hanker","m":"동경하다 / 갈망하다","p":[{"d":"동경하다 / 갈망하다","s":["yearn","crave"]}],"s":["yearn","crave"],"r":"[고대 영어] hankeren(갈망하다) → 매달려 바라다 → 동경하다, 갈망하다","type":"word","src":"Y"},{"id":3361,"vol":1,"day":27,"w":"haphazard","m":"되는 대로의 / 무계획적인","p":[{"d":"되는 대로의","s":["random","disorderly","indiscreet","aimless"]}],"s":["random","disorderly","indiscreet","aimless"],"r":"hap(chance/우연) + hazard(hazard/위험) → 우연과 위험에 맡긴 → 우연한, 계획성 없는","type":"word","src":"Y"},{"id":3362,"vol":1,"day":27,"w":"hapless","m":"불운한 / 불행한","p":[{"d":"불운한","s":["unfortunate"]}],"s":["unfortunate"],"r":"hap(luck/운) + -less(없는) → 운이 없는 → 불운한","type":"word","src":"Y"},{"id":3363,"vol":1,"day":27,"w":"harangue","m":"긴 열변 / 장광설","p":[{"d":"긴 열변 / 장광설","s":["tirade"]}],"s":["tirade"],"r":"[고대 프랑스어] arengue(speech/연설) → 긴 연설 → 대연설, 장광설","type":"word","src":"Y"},{"id":3364,"vol":1,"day":27,"w":"harass","m":"괴롭히다","p":[{"d":"괴롭히다","s":["bother","bully","harry"]}],"s":["bother","bully","harry"],"r":"[프랑스어] harer(set a dog on/개를 부추기다) → 개를 부추겨 괴롭히다 → 괴롭히다","type":"word","src":"Y"},{"id":3365,"vol":1,"day":27,"w":"harbinger","m":"전조 / 선구자","p":[{"d":"전조 / 선구자","s":["forerunner"]}],"s":["forerunner"],"r":"[고대 프랑스어] herberge(lodging/숙소)에서 유래 → 숙소를 미리 알리는 사람 → 선구자, 전조","type":"word","src":"Y"},{"id":3366,"vol":1,"day":27,"w":"harbor","m":"숨겨주다 / 품다(생각을) / 항구 / 피난처","p":[{"d":"숨겨주다 / 품다(생각을) / 항구 / 피난처","s":["refuge"]}],"s":["refuge"],"r":"[고대 영어] herebeorg(army shelter/군의 피난처) → 숨겨 주는 곳 → 피난처를 제공하다, 품다","type":"word","src":"Y"},{"id":3367,"vol":1,"day":27,"w":"hard nut to crack","m":"어려운 문제 / 다루기 힘든 사람","p":[{"d":"어려운 문제","s":["difficult problem"]}],"s":["difficult problem"],"r":"","type":"phrase","src":"Y","ex":{"en":"That math problem is a hard nut to crack.","ko":"그 수학 문