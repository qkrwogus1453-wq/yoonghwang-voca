}},{"id":3405,"vol":1,"day":27,"w":"have no business doing","m":"~할 권리가 없다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"You have no business reading my letters.","ko":"너는 내 편지를 읽을 권리가 없다."}},{"id":3406,"vol":1,"day":27,"w":"have no chance of winning","m":"이길 가망이 없다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The weak team had no chance of winning.","ko":"그 약한 팀은 이길 가망이 없었다."}},{"id":3407,"vol":1,"day":27,"w":"have no effect","m":"효과가 없다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The medicine had no effect on his cough.","ko":"그 약은 그의 기침에 효과가 없었다."}},{"id":3408,"vol":1,"day":27,"w":"have nothing to do with","m":"~와 관계가 없다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I have nothing to do with their argument.","ko":"나는 그들의 다툼과 관계가 없다."}},{"id":3409,"vol":1,"day":27,"w":"have ~ off","m":"~(날)에는 쉬다 / ~을 흉내 내다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She has Mondays off this month.","ko":"그녀는 이번 달에 월요일마다 쉰다."}},{"id":3410,"vol":1,"day":27,"w":"have one's cake and eat it, too","m":"원하는 것을 모두 얻다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"You can't spend it and save it — you can't have your cake and eat it, too.","ko":"그걸 쓰면서 저축할 순 없어. 원하는 걸 모두 얻을 순 없다."}},{"id":3411,"vol":1,"day":27,"w":"have one's hands full","m":"아주 바쁘다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She has her hands full with three young children.","ko":"그녀는 어린 세 아이로 아주 바쁘다."}},{"id":3412,"vol":1,"day":27,"w":"have one's heart set on","m":"갈망하다 / ~하려고 마음먹다","p":[{"d":"갈망하다","s":["long for"]}],"s":["long for"],"r":"","type":"phrase","src":"Y","ex":{"en":"He has his heart set on studying abroad.","ko":"그는 유학하기로 마음먹었다."}},{"id":3413,"vol":1,"day":27,"w":"have the last word","m":"마지막 발언을 하다 / 최종 결정권을 갖다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The manager always has the last word.","ko":"그 관리자는 항상 최종 결정권을 갖는다."}},{"id":3414,"vol":1,"day":27,"w":"have to do with","m":"~와 관계가 있다","p":[{"d":"~와 관계가 있다","s":["be concerned with"]}],"s":["be concerned with"],"r":"","type":"phrase","src":"Y","ex":{"en":"His job has to do with computers.","ko":"그의 일은 컴퓨터와 관계가 있다."}},{"id":3415,"vol":1,"day":27,"w":"have two left feet","m":"동작이 아주 어색하다(춤을 추는)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I can't dance at all; I have two left feet.","ko":"나는 춤을 전혀 못 춘다. 동작이 아주 어색하다."}},{"id":3416,"vol":1,"day":27,"w":"have words with","m":"~와 말다툼하다","p":[{"d":"~와 말다툼하다","s":["quarrel with"]}],"s":["quarrel with"],"r":"","type":"phrase","src":"Y","ex":{"en":"She had words with her neighbor about the noise.","ko":"그녀는 소음 문제로 이웃과 말다툼했다."}},{"id":3417,"vol":1,"day":27,"w":"have yet to do","m":"아직 ~하지 못했다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He has yet to finish the report.","ko":"그는 아직 보고서를 끝내지 못했다."}},{"id":3418,"vol":1,"day":27,"w":"haven","m":"피난처 / 항구","p":[{"d":"피난처","s":["shelter"]},{"d":"항구","s":["harbor"]}],"s":["shelter","harbor"],"r":"[고대 영어] hæfen(harbor/항구) → 배가 안전한 항구 → 항구, 안식처","type":"word","src":"Y"},{"id":3419,"vol":1,"day":27,"w":"havoc","m":"대규모 파괴 / 대혼란","p":[{"d":"대규모 파괴","s":["devastation","destruction","ruin"]},{"d":"대혼란","s":["disorder","mayhem"]}],"s":["devastation","destruction","ruin","disorder","mayhem"],"r":"[고대 프랑스어] havot(pillage/약탈) → 약탈로 인한 대파괴 → 대황폐","type":"word","src":"Y"},{"id":3420,"vol":1,"day":27,"w":"hawk","m":"강경론자 / 매파 / 소리치며 팔다 / 행상하다","p":[],"s":[],"r":"[의성어] hawk(매) → 매처럼 공격적인 쪽 → 강경론자, 매파 / 외치며 팔다 → 행상하다","type":"word","src":"Y"},{"id":3421,"vol":1,"day":27,"w":"hazard","m":"위험 / 위험 요소","p":[{"d":"위험","s":["danger"]}],"s":["danger"],"r":"[아랍어] az-zahr(dice/주사위) → 예측 불가한 위험 → 위험, 위태롭게 하다","type":"word","src":"Y"},{"id":3422,"vol":1,"day":27,"w":"hazy","m":"흐릿한 / 안개가 낀 / 막연한","p":[{"d":"흐릿한 / 안개가 낀","s":["misty"]},{"d":"막연한","s":["nebulous"]}],"s":["misty","nebulous"],"r":"haze(haze/실안개) + -y(형용사형) → 실안개가 낀 → 흐릿한, 모호한","type":"word","src":"Y"},{"id":3423,"vol":1,"day":27,"w":"head","m":"이끌다 / 나아가다 / 우두머리 / 맥주 거품 / 동전 앞면","p":[{"d":"이끌다","s":["lead"]}],"s":["lead"],"r":"[고대 영어] heafod(머리) → 머리 → 우두머리 / 머리로 향하다 → 나아가다, 이끌다","type":"word","src":"Y"},{"id":3424,"vol":1,"day":27,"w":"head for","m":"~으로 향하다 / ~할 운명이다","p":[{"d":"~으로 향하다","s":["move towards"]}],"s":["move towards"],"r":"","type":"phrase","src":"Y","ex":{"en":"We are heading for the mountains this weekend.","ko":"우리는 이번 주말에 산으로 향한다."}},{"id":3425,"vol":1,"day":27,"w":"head off","m":"저지하다 / 막다","p":[{"d":"저지하다 / 막다","s":["forestall","block","prevent"]}],"s":["forestall","block","prevent"],"r":"","type":"phrase","src":"Y","ex":{"en":"The police headed off the escape.","ko":"경찰이 그 탈출을 저지했다."}},{"id":3426,"vol":1,"day":27,"w":"head on","m":"정면으로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The two cars collided head on.","ko":"그 두 차가 정면으로 충돌했다."}},{"id":3427,"vol":1,"day":27,"w":"head over heels with","m":"~에게 푹 빠진","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He fell head over heels with her at first sight.","ko":"그는 첫눈에 그녀에게 푹 빠졌다."}},{"id":3428,"vol":1,"day":27,"w":"headache","m":"두통 / 골칫거리","p":[],"s":[],"r":"head(머리) + ache(아픔) → 머리가 아픔 → 두통, 골칫거리","type":"word","src":"Y"},{"id":3429,"vol":1,"day":27,"w":"headhunter","m":"인재 스카우트 전문가","p":[],"s":[],"r":"head(머리) + hunt(사냥) + -er(~하는 사람) → 인재의 머리를 사냥하는 사람 → 인재 스카우트 전문가","type":"word","src":"Y"},{"id":3430,"vol":1,"day":27,"w":"headquarters","m":"본부 / 본사 / 사령부","p":[],"s":[],"r":"head(머리, 우두머리) + quarters(구역) → 우두머리가 있는 곳 → 본부, 사령부","type":"word","src":"Y"},{"id":3431,"vol":1,"day":27,"w":"headstrong","m":"고집 센 / 완고한","p":[{"d":"고집 센 / 완고한","s":["stubborn","obstinate"]}],"s":["stubborn","obstinate"],"r":"head(head/머리) + strong(strong/강한) → 머리가 강한 → 완고한, 고집 센","type":"word","src":"Y"},{"id":3432,"vol":1,"day":27,"w":"headway","m":"진행 / 진보","p":[{"d":"진행 / 진보","s":["progress"]}],"s":["progress"],"r":"head(머리, 앞) + way(길) → 뱃머리가 나아가는 길 → 진행, 진보","type":"word","src":"Y"},{"id":3433,"vol":1,"day":27,"w":"heal","m":"치유되다