ur","m":"밀가루","p":[],"s":[],"r":"[flower(꽃, 알맹이)의 변형] flour → 곡물의 고운 알맹이 → 밀가루","type":"word","src":"Y"},{"id":9614,"vol":2,"day":10,"w":"flub","m":"망치다 / 실수하다 / 실수","p":[{"d":"망치다 / 실수하다","s":["bungle"]}],"s":["bungle"],"r":"[flop + fluff 혼성] flub → 어설프게 하다 → 망치다, 실수하다","type":"word","src":"Y"},{"id":9615,"vol":2,"day":10,"w":"flurry","m":"소동 / 질풍","p":[],"s":[],"r":"[flurr(휘몰아치다)에서] flurry → 갑자기 몰아침 → 소동, 질풍","type":"word","src":"Y"},{"id":9616,"vol":2,"day":10,"w":"fluffy","m":"솜털 같은 / 하찮은","p":[],"s":[],"r":"[fluff(솜털)에서] fluffy → 솜털 같은 → 솜털 같은, 하찮은","type":"word","src":"Y"},{"id":9617,"vol":2,"day":10,"w":"fly in the ointment","m":"옥에 티","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The delay was the only fly in the ointment.","ko":"그 지연이 유일한 옥에 티였다."}},{"id":9618,"vol":2,"day":10,"w":"fly off the handle","m":"화내다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He flew off the handle over a small mistake.","ko":"그는 작은 실수에 화를 냈다."}},{"id":9619,"vol":2,"day":10,"w":"focus group","m":"초점 집단(시장 조사나 여론 조사를 위해 각 계층을 대표하도록 뽑은 사람들로 이루어진)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The company tested the ad with a focus group.","ko":"그 회사는 초점 집단으로 그 광고를 시험했다."}},{"id":9620,"vol":2,"day":10,"w":"fodder","m":"먹이(가축의) / 사료 / 소재(작품의)","p":[{"d":"먹이(가축의) / 사료","s":["forage"]},{"d":"소재(작품의)","s":["material"]}],"s":["forage","material"],"r":"[고대 영어] fodor(먹이) → 가축의 먹이 → 먹이, 사료, 소재","type":"word","src":"Y"},{"id":9621,"vol":2,"day":10,"w":"foist","m":"속여서 팔다 / 강요하다 / 억지로 떠맡기다","p":[{"d":"속여서 팔다","s":["palm"]},{"d":"강요하다","s":["impose"]}],"s":["palm","impose"],"r":"[foist, 손에 몰래 쥐여주다] → 슬쩍 떠넘기다 → 속여서 팔다, 억지로 떠맡기다","type":"word","src":"Y"},{"id":9622,"vol":2,"day":10,"w":"folderol","m":"헛소리 / 하찮은 물건","p":[{"d":"헛소리","s":["nonsense"]}],"s":["nonsense"],"r":"[프랑스 후렴구 falderal에서] folderol → 뜻 없는 후렴 → 헛소리, 하찮은 물건","type":"word","src":"Y"},{"id":9623,"vol":2,"day":10,"w":"follow through on","m":"~을 완수하다","p":[],"s":[],"r":"","type":"phrase","sr