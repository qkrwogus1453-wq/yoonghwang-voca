[{"id":9721,"vol":2,"day":11,"w":"garden-variety","m":"흔한 / 보통의","p":[],"s":[],"r":"garden(정원) + variety(품종) → 정원에 흔한 품종의 → 흔한, 보통의","type":"word","src":"Y"},{"id":9722,"vol":2,"day":11,"w":"gargle","m":"목을 가시다 / 구강 청정제","p":[],"s":[],"r":"[의성어] gargle(가글) ← 라틴어 gargarizare → 목구멍에서 소리 내다 → 목을 가시다, 구강 청정제","type":"word","src":"Y"},{"id":9723,"vol":2,"day":11,"w":"gargoyle","m":"괴물 형상의 홈통 주둥이","p":[],"s":[],"r":"[고대 프랑스어] gargouille(목구멍) → 물이 목구멍처럼 나오는 조각 → 괴물 형상의 홈통 주둥이","type":"word","src":"Y"},{"id":9724,"vol":2,"day":11,"w":"garish","m":"천박하게 화려한 / 지나치게 꾸민","p":[{"d":"천박하게 화려한 / 지나치게 꾸민","s":["gaudy"]}],"s":["gaudy"],"r":"[중세 영어] gaure(stare/응시하다) + -ish(~같은) → 눈길을 끌 만큼 화려한 → 지나치게 화려한, 야한","type":"word","src":"Y"},{"id":9725,"vol":2,"day":11,"w":"garland","m":"화환 / 화관","p":[{"d":"화환 / 화관","s":["wreath"]}],"s":["wreath"],"r":"[고대 프랑스어] garlande(circlet/화환) → 꽃으로 만든 원형 장식 → 화환","type":"word","src":"Y"},{"id":9726,"vol":2,"day":11,"w":"garnish","m":"장식하다 / 꾸미다(미사여구로) / 고명(음식의) / 장식품","p":[{"d":"장식하다","s":["decorate"]}],"s":["decorate"],"r":"garn(equip/갖추다) + -ish(~같은) → 갖춰 꾸미다 → 장식하다, 고명을 곁들이다","type":"word","src":"Y"},{"id":9727,"vol":2,"day":11,"w":"garrison","m":"수비대 / 주둔군 / 주둔지","p":[],"s":[],"r":"[고대 프랑스어] garnison(supply/공급) → 방어를 위해 배치된 군대 → 수비대, 주둔군","type":"word","src":"Y"},{"id":9728,"vol":2,"day":11,"w":"gasp","m":"헐떡거리다 / 숨이 막히다 / 헐떡거림","p":[{"d":"헐떡거리다","s":["pant"]}],"s":["pant"],"r":"[고대 노르드어] geispa(yawn/하품하다) → 숨이 막혀 헐떡이다 → 헐떡거리다","type":"word","src":"Y"},{"id":9729,"vol":2,"day":11,"w":"gauche","m":"서투른 / 세련되지 못한","p":[{"d":"서투른","s":["awkward"]}],"s":["awkward"],"r":"[프랑스어] gauche(left/왼쪽)에서 유래 → 왼손잡이처럼 서투른 → 솜씨가 서투른","type":"word","src":"Y"},{"id":9730,"vol":2,"day":11,"w":"gaunt","m":"몹시 여윈 / 수척한","p":[{"d":"몹시 여윈 / 수척한","s":["haggard"]}],"s":["haggard"],"r":"[스칸디나비아어] gant(thin/여윈) → 몹시 여윈 → 수척한, 황량한","type":"word","src":"Y"},{"id":9731,"vol":2,"day":11,"w":"gawky","m":"어색해 보이는 / 볼품없는","p":[{"d":"어색해 보이는","s":["awkward"]},{"d":"볼품없는","s":["ungai