ol":2,"day":11,"w":"get it off one's chest","m":"마음을 털어놓다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She felt better after getting it off her chest.","ko":"그녀는 마음을 털어놓은 후 기분이 나아졌다."}},{"id":9762,"vol":2,"day":11,"w":"get off on the wrong foot","m":"출발이 잘못되다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The project got off on the wrong foot.","ko":"그 프로젝트는 출발이 잘못되었다."}},{"id":9763,"vol":2,"day":11,"w":"get off to a flying start","m":"순조롭게 출발하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The team got off to a flying start.","ko":"그 팀은 순조롭게 출발했다."}},{"id":9764,"vol":2,"day":11,"w":"get on like a house on fire","m":"급속히 친해지다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The two new students got on like a house on fire.","ko":"그 두 전학생은 급속히 친해졌다."}},{"id":9765,"vol":2,"day":11,"w":"get on to","m":"(새로운 화제)에 대해 이야기를 시작하다 / ~에 착수하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Let's get on to the next topic.","ko":"다음 화제로 넘어가자."}},{"id":9766,"vol":2,"day":11,"w":"get on with","m":"사이좋게 지내다 / 계속하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She gets on well with her coworkers.","ko":"그녀는 동료들과 사이좋게 지낸다."}},{"id":9767,"vol":2,"day":11,"w":"get one's feet wet","m":"시작해 보다(새로운 일을) / 참가하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The internship let her get her feet wet in law.","ko":"그 인턴십은 그녀가 법 분야를 처음 시작해 보게 했다."}},{"id":9768,"vol":2,"day":11,"w":"get one's head round","m":"이해하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"I can't get my head round the new rules.","ko":"나는 새 규칙을 이해할 수 없다."}},{"id":9769,"vol":2,"day":11,"w":"get one's way","m":"바라던 것을 얻다 / 마음대로 하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The spoiled child always gets his way.","ko":"그 버릇없는 아이는 늘 자기 마음대로 한다."}},{"id":9770,"vol":2,"day":11,"w":"get out","m":"나가다 / 도망치다 / 새어 나오다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The secret got out despite their efforts.","ko":"그들의 노력에도 비밀이 새어 나왔다."}},{"id":9771,"vol":2,"day":11,"w":"get set","m":"준비를 갖추다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Get set for the race.","ko":"경주 준비를 갖춰라."}},{"id":9772,"vol":2,"day":11,"w":"get smart with","m":"~에게 건방지게 굴다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Don't get smart with your teacher.","ko":"선생님에게 건방지게 굴지 마라."}},{"id":9773,"vol":2,"day":11,"w":"get somewhere","m":"진전을 보다 / 성공하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"After hours of talks, we finally got somewhere.","ko":"몇 시간의 논의 끝에 우리는 마침내 진전을 봤다."}},{"id":9774,"vol":2,"day":11,"w":"get sore","m":"화를 내다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He got sore when they teased him.","ko":"그들이 놀리자 그는 화를 냈다."}},{"id":9775,"vol":2,"day":11,"w":"get the ax","m":"해고당하다","p":[{"d":"해고당하다","s":["get the gate","get dismissed"]}],"s":["get the gate","get dismissed"],"r":"","type":"phrase","src":"Y","ex":{"en":"He got the ax after the merger.","ko":"그는 합병 후 해고당했다."}},{"id":9776,"vol":2,"day":11,"w":"get the boot","m":"해고당하다","p":[{"d":"해고당하다","s":["get the pink slip"]}],"s":["get the pink slip"],"r":"","type":"phrase","src":"Y","ex":{"en":"She got the boot for being late too often.","ko":"그녀는 너무 자주 늦어서 해고당했다."}},{"id":9777,"vol":2,"day":11,"w":"get the message","m":"진의를 파악하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"After her hint, he finally got the message.","ko":"그녀의 암시 후 그는 마침내 진의를 파악했다."}},{"id":9778,"vol":2,"day":11,"w":"get the short end of the stick","m":"손해를 보다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He always gets the short end of the stick.","ko":"그는 늘 손해를 본다."}},{"id":9779,"vol":2,"day":11,"w":"get the word out","m":"말을 퍼뜨리다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"They got the word out about the fundraiser.","ko":"그들은 모금 행사에 대한 말을 퍼뜨렸다."}},{"id":9780,"vol":2,"day":11,"w":"get through","m":"극복하다 / 이해시키다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex"