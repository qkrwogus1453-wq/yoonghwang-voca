rmy","m":"육군 / 군대","p":[],"s":[],"r":"[라틴어] arma(무기) → 무기를 든 무리 → 육군, 군대","type":"word","src":"Y"},{"id":8299,"vol":2,"day":2,"w":"aroma","m":"향기","p":[{"d":"향기","s":["fragrance"]}],"s":["fragrance"],"r":"[그리스어] aroma(향신료) → 향긋한 냄새 → 향기","type":"word","src":"Y"},{"id":8300,"vol":2,"day":2,"w":"arraign","m":"~에게 죄상의 진위 여부를 묻다(법원에 소환하여)","p":[],"s":[],"r":"ar(to/~쪽으로) + raign(reason/이유) → 이유를 대라고 소환하다 → 법정에 소환하다","type":"word","src":"Y"},{"id":8301,"vol":2,"day":2,"w":"arrant","m":"악명 높은 / 순전한","p":[{"d":"악명 높은","s":["notorious"]},{"d":"순전한","s":["utter"]}],"s":["notorious","utter"],"r":"errant(wandering/방랑하는)에서 유래 → 완전히 벗어난 → 순전한, 악명 높은","type":"word","src":"Y"},{"id":8302,"vol":2,"day":2,"w":"array","m":"배치 / 나열 / 옷 / 정렬시키다 / 차려 입히다","p":[{"d":"배치 / 나열 / 옷 / 정렬시키다","s":["arrange"]}],"s":["arrange"],"r":"ar(to/~쪽으로) + ray(order/배열하다) → 줄지어 배열하다 → 정렬시키다, 배열","type":"word","src":"Y"},{"id":8303,"vol":2,"day":2,"w":"arrears","m":"연체금 / 지연","p":[{"d":"연체금","s":["overdue debt"]}],"s":["overdue debt"],"r":"ar(to/~에) + rear(behind/뒤) + -s(어형 변화) → 뒤로 밀린 것 → 연체금, 지연","type":"word","src":"Y"},{"id":8304,"vol":2,"day":2,"w":"arrogate","m":"침해하다 / 사칭하다 / 횡령하다","p":[],"s":[],"r":"ar(to/~쪽으로) + rog(ask/요구하다) + -ate(동사형) → 함부로 요구하다 → 가로채다, 사칭하다","type":"word","src":"Y"},{"id":8305,"vol":2,"day":2,"w":"arsenic","m":"비소","p":[],"s":[],"r":"[그리스어] arsenikon(yellow orpiment/황화 광물)에서 유래 → 노란 광물에서 추출한 것 → 비소","type":"word","src":"Y","uf":["화학"]},{"id":8306,"vol":2,"day":2,"w":"artery","m":"동맥 / 주요 도로","p":[],"s":[],"r":"arter(artery/동맥) + -y(형용사형) → 혈액이 흐르는 주요 통로 → 동맥, 주요 도로","type":"word","src":"Y"},{"id":8307,"vol":2,"day":2,"w":"artful","m":"기교를 부리는 / 교활한","p":[{"d":"기교를 부리는 / 교활한","s":["cunning"]}],"s":["cunning"],"r":"art(skill/기술) + -ful(가득한) → 기술이 가득한 → 교활한, 교묘한","type":"word","src":"Y"},{"id":8308,"vol":2,"day":2,"w":"arthropod","m":"절지 동물(ex 곤충)","p":[],"s":[],"r":"arthro(joint/마디) + pod(foot/발) → 발에 마디가 있는 것 → 절지 동물","type":"word","src":"Y"},{"id":8309,"vol":2,"day":2,"w":"artillery","m":"포병 / 대포","p":[],"s":[],"r":"[고대 프랑스어] artillier(무기를 갖추다) → 큰 무기 → 포병, 대포","type":"word","src":"Y"},{"id":8310,"vol":2,"day":2,"w":"artless","m":"꾸밈없는 / 기술 없는","p":[{"d":"꾸밈없는","s":["natural","ingenuous"]},{"d":"기술 없는","s":["unskilled"]}],"s":["natural","ingenuous","unskilled"],"r":"art(기술) + -less(없는) → 꾸밈 기술이 없는 → 꾸밈없는, 기술 없는","type":"word","src":"Y"},{"id":8311,"vol":2,"day":2,"w":"as a result of","m":"~의 결과로","p":[{"d":"~의 결과로","s":["because of"]}],"s":["because of"],"r":"","type":"phrase","src":"Y","ex":{"en":"The delay came as a result of heavy rain.","ko":"그 지연은 폭우의 결과로 생겼다."}},{"id":8312,"vol":2,"day":2,"w":"as cool as a cucumber","m":"아주 침착한","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She stayed as cool as a cucumber during the crisis.","ko":"그녀는 위기 동안 아주 침착함을 유지했다."}},{"id":8313,"vol":2,"day":2,"w":"as cute as a button","m":"귀여운","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The baby is as cute as a button.","ko":"그 아기는 아주 귀엽다."}},{"id":8314,"vol":2,"day":2,"w":"as dry as a bone","m":"바싹 마른 / 앙상한","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The soil was as dry as a bone after the drought.","ko":"가뭄 후 흙이 바싹 말라 있었다."}},{"id":8315,"vol":2,"day":2,"w":"as far as ~ be concerned","m":"~에 관한 한","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"As far as I'm concerned, the plan is fine.","ko":"나에 관한 한 그 계획은 괜찮다."}},{"id":8316,"vol":2,"day":2,"w":"as follows","m":"다음과 같이","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The steps are as follows.","ko":"단계는 다음과 같다."}},{"id":8317,"vol":2,"day":2,"w":"as good as","m":"~나 마찬가지인","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The job is as good as done.","ko":"그 일은 다 된 거나 마찬가지다."}},{"id":8318,"vol":2,"day":2,"w":"as hungry as a bear","m":"아주 배고픈","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"After the long hike, I was as hungry as a bear.","ko":"긴 하이킹 후 나는 아주 배가 고팠다."}},{"id":8319,"vol":2,"day":2,"w":"as it happens","m":"