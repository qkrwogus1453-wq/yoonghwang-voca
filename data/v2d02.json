:8403,"vol":2,"day":2,"w":"backbreaking","m":"아주 힘든","p":[],"s":[],"r":"back(등) + breaking(부수는) → 허리가 부서질 듯한 → 아주 힘든","type":"word","src":"Y"},{"id":8404,"vol":2,"day":2,"w":"background check","m":"신원 조사","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The company ran a background check on the applicant.","ko":"그 회사는 지원자에 대한 신원 조사를 했다."}},{"id":8405,"vol":2,"day":2,"w":"backhanded compliment","m":"비꼬는 투의 칭찬","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"\"Not bad for a beginner\" felt like a backhanded compliment.","ko":"\"초보치고는 나쁘지 않네\"는 비꼬는 투의 칭찬 같았다."}},{"id":8406,"vol":2,"day":2,"w":"backlog","m":"밀린 일거리","p":[],"s":[],"r":"back(뒤) + log(쌓인 것) → 뒤로 쌓인 것 → 밀린 일거리","type":"word","src":"Y"},{"id":8407,"vol":2,"day":2,"w":"backroom deal","m":"밀실 거래","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The contract was arranged in a backroom deal.","ko":"그 계약은 밀실 거래로 성사되었다."}},{"id":8408,"vol":2,"day":2,"w":"backslide","m":"악습으로 되돌아가다 / 퇴보하다","p":[{"d":"악습으로 되돌아가다","s":["lapse","relapse"]}],"s":["lapse","relapse"],"r":"back(뒤로) + slide(미끄러지다) → 뒤로 미끄러지다 → 악습으로 되돌아가다, 퇴보하다","type":"word","src":"Y"},{"id":8409,"vol":2,"day":2,"w":"back-to-back","m":"연이은","p":[{"d":"연이은","s":["one after the other","consecutive"]}],"s":["one after the other","consecutive"],"r":"back(등) + to(to/~쪽으로) + back(등) → 등을 맞대고 잇따라 → 연이은","type":"word","src":"Y"},{"id":8410,"vol":2,"day":2,"w":"backtrack on","m":"철회하다","p":[{"d":"철회하다","s":["retract","recant"]}],"s":["retract","recant"],"r":"","type":"phrase","src":"Y","ex":{"en":"The politician backtracked on his promise.","ko":"그 정치인은 자신의 약속을 철회했다."}},{"id":8411,"vol":2,"day":2,"w":"backward","m":"뒤쪽으로 / 거꾸로 / 소급하여 / 뒤쪽의 / 뒤떨어진 / 낙후된","p":[],"s":[],"r":"back(뒤) + -ward(쪽으로) → 뒤쪽으로 → 거꾸로, 뒤떨어진","type":"word","src":"Y"}]