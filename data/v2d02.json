rase","src":"Y","ex":{"en":"She could read the music at sight.","ko":"그녀는 그 악보를 보자마자 읽을 수 있었다."}},{"id":8361,"vol":2,"day":2,"w":"at sixes and sevens","m":"혼란스러운 / 일치하지 않는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"After the news, the office was at sixes and sevens.","ko":"그 소식 후 사무실은 혼란스러웠다."}},{"id":8362,"vol":2,"day":2,"w":"at the bottom of one's heart","m":"내심으로는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"At the bottom of her heart, she still cared.","ko":"내심으로는 그녀는 여전히 신경 쓰고 있었다."}},{"id":8363,"vol":2,"day":2,"w":"at the core of","m":"~의 핵심에","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Trust is at the core of their friendship.","ko":"신뢰가 그들 우정의 핵심에 있다."}},{"id":8364,"vol":2,"day":2,"w":"at the latest","m":"늦어도","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Submit the form by Friday at the latest.","ko":"늦어도 금요일까지 그 양식을 제출해라."}},{"id":8365,"vol":2,"day":2,"w":"at will","m":"마음대로 / 뜻대로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She can cry at will for the role.","ko":"그녀는 그 역을 위해 마음대로 울 수 있다."}},{"id":8366,"vol":2,"day":2,"w":"atavism","m":"격세유전 / 이전 상태로 되돌아감","p":[{"d":"격세유전","s":["throwback"]},{"d":"이전 상태로 되돌아감","s":["reversion"]}],"s":["throwback","reversion"],"r":"ata(v)(ancestor/조상) + -ism(주의) → 조상의 형질이 되살아남 → 격세유전","type":"word","src":"Y"},{"id":8367,"vol":2,"day":2,"w":"atelier","m":"작업실 / 화실","p":[{"d":"작업실 / 화실","s":["studio"]}],"s":["studio"],"r":"[프랑스어] atelier(작업장) ← 라틴어 astella(나무 조각) → 장인의 작업장 → 작업실, 화실","type":"word","src":"Y"},{"id":8368,"vol":2,"day":2,"w":"atomic","m":"원자의 / 원자력을 이용한","p":[],"s":[],"r":"atom(원자) + -ic(형용사형) → 원자의 → 원자의, 원자력을 이용한","type":"word","src":"Y"},{"id":8369,"vol":2,"day":2,"w":"atop","m":"꼭대기에","p":[],"s":[],"r":"a(on/~에) + top(꼭대기) → 꼭대기에 → 꼭대기에","type":"word","src":"Y"},{"id":8370,"vol":2,"day":2,"w":"attempted","m":"미수에 그친","p":[],"s":[],"r":"at(to/~에) + tempt(try/시도하다) + -ed(~된) → 시도했으나 못 이룬 → 미수에 그친","type":"word","src":"Y"},{"id":8371,"v