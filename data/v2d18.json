8,"w":"on the boards","m":"상연 중인","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The play is on the boards this week.","ko":"그 연극이 이번 주에 상연 중이다."}},{"id":11017,"vol":2,"day":18,"w":"on the face of it","m":"표면상 / 겉보기에는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"On the face of it, the deal looks good.","ko":"겉보기에는 그 거래가 좋아 보인다."}},{"id":11018,"vol":2,"day":18,"w":"on the house","m":"공짜로 / 술집 부담으로","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The first drink is on the house.","ko":"첫 잔은 공짜다."}},{"id":11019,"vol":2,"day":18,"w":"on the increase","m":"증가하여","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Crime is on the increase in the area.","ko":"그 지역에서 범죄가 증가하고 있다."}},{"id":11020,"vol":2,"day":18,"w":"on the move","m":"활동적인 / 여행 중인 / 진행되고 있는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The busy manager is always on the move.","ko":"그 바쁜 관리자는 늘 활동적이다."}},{"id":11021,"vol":2,"day":18,"w":"on the point of","m":"막 ~하려는 순간에","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"She was on the point of leaving when he called.","ko":"그가 전화했을 때 그녀는 막 떠나려던 참이었다."}},{"id":11022,"vol":2,"day":18,"w":"on the qui vive","m":"경계하여","p":[{"d":"경계하여","s":["on the lookout"]}],"s":["on the lookout"],"r":"","type":"phrase","src":"Y","ex":{"en":"The guards were on the qui vive all night.","ko":"경비원들은 밤새 경계했다."}},{"id":11023,"vol":2,"day":18,"w":"on the rocks","m":"파탄 직전인 / 얼음을 넣은(술이)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Their marriage is on the rocks.","ko":"그들의 결혼 생활은 파탄 직전이다."}},{"id":11024,"vol":2,"day":18,"w":"on the run","m":"도망쳐 / 경찰에 쫓겨","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The thief has been on the run for weeks.","ko":"그 도둑은 몇 주째 도망 다니고 있다."}},{"id":11025,"vol":2,"day":18,"w":"on the square","m":"정직하게","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He always deals on the square.","ko":"그는 늘 정직하게 거래한다."}},{"id":11026,"vol":2,"day":18,"w":"on the spur",