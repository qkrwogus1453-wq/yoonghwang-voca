[{"id":10870,"vol":2,"day":18,"w":"Neolithic","m":"신석기 시대 / 신석기 시대의","p":[],"s":[],"r":"neo(new/새로운) + lith(stone/돌) + -ic(형용사형) → 새 돌을 쓰던 시대의 → 신석기 시대의","type":"word","src":"Y"},{"id":10871,"vol":2,"day":18,"w":"neon","m":"네온 / 휘황찬란한","p":[],"s":[],"r":"[그리스어] neon(new/새로운) → 새로 발견된 기체 → 네온, 휘황찬란한","type":"word","src":"Y"},{"id":10872,"vol":2,"day":18,"w":"neophyte","m":"신개종자 / 초심자","p":[{"d":"신개종자","s":["recent convert"]},{"d":"초심자","s":["novice"]}],"s":["recent convert","novice"],"r":"neo(new/새로운) + phyt(planted/심어진) → 새로 심어진 사람 → 초보자, 신개종자","type":"word","src":"Y"},{"id":10873,"vol":2,"day":18,"w":"nestle","m":"자리 잡게 하다 / 편안하게 눕다","p":[],"s":[],"r":"[고대 영어] nestlian(둥지를 틀다) → 둥지처럼 파고들다 → 자리 잡게 하다, 편안하게 눕다","type":"word","src":"Y"},{"id":10874,"vol":2,"day":18,"w":"neuroeconomics","m":"신경 경제학","p":[],"s":[],"r":"neuro(nerve/신경) + economics(경제학) → 신경을 다루는 경제학 → 신경 경제학","type":"word","src":"Y"},{"id":10875,"vol":2,"day":18,"w":"neuron","m":"뉴런 / 신경 세포","p":[],"s":[],"r":"[그리스어] neuron(nerve/신경) → 신경 세포 → 뉴런, 신경 세포","type":"word","src":"Y"},{"id":10876,"vol":2,"day":18,"w":"neurosis","m":"신경증","p":[],"s":[],"r":"[그리스어] neuron(nerve/신경) + -osis(병적 상태) → 신경의 병적 상태 → 신경증, 노이로제","type":"word","src":"Y"},{"id":10877,"vol":2,"day":18,"w":"never mind","m":"~은 고사하고","p":[{"d":"~은 고사하고","s":["let alone"]}],"s":["let alone"],"r":"","type":"phrase","src":"Y","ex":{"en":"He can't afford a car, never mind a house.","ko":"그는 집은 고사하고 차도 살 여유가 없다."}},{"id":10878,"vol":2,"day":18,"w":"newbie","m":"신출내기 / 미숙련자","p":[{"d":"신출내기","s":["newcomer"]}],"s":["newcomer"],"r":"[new(새로운) + -bie] → 갓 들어온 이 → 신출내기, 미숙련자","type":"word","src":"Y"},{"id":10879,"vol":2,"day":18,"w":"newfangled","m":"최신 유행의 / 신기한","p":[],"s":[],"r":"new(new/새로운) + fangled(seize/붙잡은) → 새로 붙잡은 것을 좋아하는 → 신식의, 새것을 좋아하는","type":"word","src":"Y"},{"id":10880,"vol":2,"day":18,"w":"newly","m":"최근에 / 새롭게","p":[],"s":[],"r":"new(새로운) + -ly(부사형) → 새롭게 → 최근에, 새롭게","type":"word","src":"Y"},{"id":10881,"vol":2,"day":18,"w":"newlywed","m":"신혼의","p":[],"s":[],"r":"newly(새롭게) + wed(결혼한) → 갓 결혼한 → 신혼의","type":"word","src":"Y"},{"id":10882,"vol":2,"day":18,"w":"news embargo","m":"보도 유예 요청","p":[{"d":"보도 유예 요청","s":["press embargo"]}],"s":["press embargo"],"r":"","type":"phrase","src":"Y","ex":{"en":"The company placed a news embargo on the results.","ko":"그 회사는 결과에 대해 보도 유예를 요청했다."}},{"id":10883,"vol":2,"day":18,"w":"newsworthy","m":"보도 가치가 있는 / 기사거리가 되는","p":[],"s":[],"r":"news(뉴스) + worthy(가치 있는) → 보도할 가치가 있는 → 보도 가치가 있는","type":"word","src":"Y"},{"id":10884,"vol":2,"day":18,"w":"next but one","m":"하나 다음 / 다음다음","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Her house is the next but one on the street.","ko":"그녀의 집은 그 거리에서 다음다음 집이다."}},{"id":10885,"vol":2,"day":18,"w":"next-to-last","m":"끝에서 두 번째의","p":[{"d":"끝에서 두 번째의","s":["last but one","penultimate"]}],"s":["last but one","penultimate"],"r":"next(다음) + to(to/~쪽으로) + last(마지막) → 마지막 바로 앞의 → 끝에서 두 번째의","type":"word","src":"Y"},{"id":10886,"vol":2,"day":18,"w":"nexus","m":"연계 / 관계","p":[{"d":"연계","s":["connection"]}],"s":["connection"],"r":"nex(bind/묶다) + -us(명사형) → 묶어 연결하는 것 → 결합, 유대","type":"word","src":"Y"},{"id":10887,"vol":2,"day":18,"w":"nib","m":"부리(새의) / 펜촉 / 첨단","p":[],"s":[],"r":"[nib(끝)에서] ← 고대 영어 nebb(부리) → 뾰족한 끝 → 부리, 펜촉, 첨단","type":"word","src":"Y"},{"id":10888,"vol":2,"day":18,"w":"nibble","m":"조금씩 뜯어먹다 / 잠식하다","p":[{"d":"조금씩 뜯어먹다","s":["bite"]}],"s":["bite"],"r":"[중세 영어] nebyllen(nibble/조금씩 물다) → 조금씩 물어뜯다 → 조금씩 물어뜯다","type":"word","src":"Y"},{"id":10889,"vol":2,"day":18,"w":"niche in the temple of fame","m":"불후의 명성","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The scientist earned a niche in the temple of fame.","ko":"그 과학자는 불후의 명성을 얻었다."}},{"id":10890,"vol":2,"day":18,"w":"nick","m":"새긴 눈금 / 깨진 곳 / 철창 / 줄이다 / 속이다","p":[{"d":"새긴 눈금","s":["notch"]}],"s":["notch"],"r":"[중세 영어] nik(새긴 자국) → 칼로 낸 자국 → 새긴 눈금, 깨진 곳","type":"word","src":"Y"},{"id":10891,"vol":2,"day":18,"w":"nickelodeon","m":"5센트 극장(20세기 초)","p":[],"s":[],"r":"nickel(5센트) + odeon(theater/극장) → 5센트짜리 극장 → 5센트 극장","type":"word","src":"Y"},{"id":10892,"vol":2,"day":18,"w":"nifty","m":"멋진 / 맵시 있는 / 재치 있는","p":[{"d":"멋진 / 맵시 있는 / 재치 있는","s":["smart"]}],"s":["smart"],"r":"[magnificent(멋진)에서 온 속어] nifty → 멋진 → 멋진, 재치 있는","type":"word","src":"Y"},{"id":10893,"vol":2,"day":18,"w":"niggling","m":"하찮은 일에 마음을 쓰는 / 좀스러운","p":[{"d":"하찮은 일에 마음을 쓰는 / 좀스러운","s":["petty"]}],"s":["petty"],"r":"[niggle(하찮은 일에 매달리다) + -ing] → 좀스럽게 구는 → 하찮은 일에 마음을 쓰는, 좀스러운","type":"word","src":"Y"},{"id":10894,"vol":2,"day":18,"w":"nigh","m":"가까운 / 가까이","p":[],"s":[],"r":"[고대 영어] neah(가까운) → 가까이 → 가까운, 가까이","type":"word","src":"Y"},{"id":10895,"vol":2,"day":18,"w":"nightcap","m":"자기 전에 마시는 술","p":[],"s":[],"r":"night(밤) + cap(모자, 마무리) → 자기 전 마지막 잔 → 자기 전에 마시는 술","type":"word","src":"Y"},{"id":10896,"vol":2,"day":18,"w":"nil","m":"영 / 무","p":[{"d":"영","s":["zero"]}],"s":["zero"],"r":"[라틴어] nihil(nothing/아무것도)의 축약 nil → 아무것도 없음 → 영, 무","type":"word","src":"Y"},{"id":10897,"vol":2,"day":18,"w":"nine to five","m":"아침 9시에서 오후 5시까지의 보통 근무 시간","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He works a nine to five job at the bank.","ko":"그는 은행에서 아침 9시부터 오후 5시까지 근무한다."}},{"id":10898,"vol":2,"day":18,"w":"nip","m":"꼬집다 / 죄다 / 물다 / 잘라내다","p":[{"d":"꼬집다","s":["pinch"]}],"s":["pinch"],"r":"[중세 영어] nippen(집다) → 꼬집다 → 꼬집다, 물다, 잘라내다","type":"word","src":"Y"},{"id":10899,"vol":2,"day":18,"w":"nip at one's heels","m":"바짝 뒤따르다","p":[{"d":"바짝 뒤따르다","s":["follow very closely"]}],"s":["follow very closely"],"r":"","type":"phrase","src":"Y","ex":{"en":"The rival team was nipping at our heels all season.","ko":"그 상대 팀이 시즌 내내 우리를 바짝 뒤따랐다."}},{"id":10900,"vol":2,"day":18,"w":"nip ~ in the bud","m":"~을 미연에 방지하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The manager nipped the problem in the bud.","ko":"그 관리자는 그 문제를 미연에 방지했다."}},{"id":10901,"vol":2,"day":18,"w":"nippy","m":"추운 / 살을 에는 듯한","p":[],"s":[],"r":"[nip(에는 추위) + -py] → 살을 에는 → 추운, 살을 에는 듯한","type":"word","src":"Y"},{"id":10902,"vol":2,"day":18,"w":"nix","m":"금지하다 / 거부하다 / 무","p":[{"d":"금지하다 / 거부하다 / 무","s":["nothing"]}],"s":["nothing"],"r":"[독일어] nichts(아무것도)에서 nix → 없던 일로 하다 → 금지하다, 거부하다, 무","type":"word","src":"Y"},{"id":10903,"vol":2,"day":18,"w":"no later than","m":"늦어도 ~까지는","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Submit the form no later than Friday.","ko":"늦어도 금요일까지는 그 양식을 제출해라."}},{"id":10904,"vol":2,"day":18,"w":"No Tipping.","m":"쓰레기를 버리지 마시오.","p":[{"d":"쓰레기를 버리지 마시오.","s":["No Dumping"]}],"s":["No Dumping"],"r":"","type":"phrase","src":"Y"},{"id":10905,"vol":2,"day":18,"w":"noblesse oblige","m":"높은 신분에 따르는 도덕적 의무","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"As a leader, he felt a sense of noblesse oblige.","ko":"지도자로서 그는 높은 신분에 따르는 도덕적 의무를 느꼈다."}},{"id":10906,"vol":2,"day":18,"w":"no-brainer","m":"쉬운 결정","p":[],"s":[],"r":"no(없는) + brainer(머리 쓸 일) → 머리 쓸 필요 없는 → 쉬운 결정","type":"word","src":"Y"},{"id":10907,"vol":2,"day":18,"w":"node","m":"접속점 / 매듭 / 얽힘 / 마디","p":[{"d":"접속점 / 매듭","s":["knot"]}],"s":["knot"],"r":"[라틴어] nodus(매듭) → 이어지는 매듭 → 접속점, 매듭, 마디","type":"word","src":"Y"},{"id":10908,"vol":2,"day":18,"w":"nodule","m":"작은 혹 / 뿌리혹 / 결절(인체의)","p":[],"s":[],"r":"nod(ule)(knot/매듭) → 작은 매듭 → 작은 혹, 뿌리혹, 결절","type":"word","src":"Y"},{"id":10909,"vol":2,"day":18,"w":"no-holds-barred","m":"모든 수단이 허용되는 / 어떤 제약도 없는","p":[{"d":"모든 수단이 허용되는 / 어떤 제약도 없는","s":["unrestrained"]}],"s":["unrestrained"],"r":"no(없는) + holds(잡기) + barred(금지된) → 어떤 잡기도 금지 안 된 → 모든 수단이 허용되는","type":"word","src":"Y"},{"id":10910,"vol":2,"day":18,"w":"noisome","m":"악취가 나는 / 해로운","p":[{"d":"악취가 나는 / 해로운","s":["noxious","harmful"]}],"s":["noxious","harmful"],"r":"[고대 영어] noy(harm/해) → 역겨운 냄새로 해를 끼치는 → 불쾌한, 해로운","type":"word","src":"Y"},{"id":10911,"vol":2,"day":18,"w":"nom de plume","m":"필명","p":[{"d":"필명","s":["pen name","pseudonym"]}],"s":["pen name","pseudonym"],"r":"","type":"phrase","src":"Y","ex":{"en":"She writes under a nom de plume.","ko":"그녀는 필명으로 글을 쓴다."}},{"id":10912,"vol":2,"day":18,"w":"nomophobia","m":"노모포비아(\"no mobile phobia\", 휴대 전화가 없을 때 느끼는 공포증)","p":[],"s":[],"r":"no(없는) + mo(bile)(휴대폰) + phob(fear/두려움) + -ia(명사형(상태)) → 휴대폰이 없을까 두려움 → 노모포비아","type":"word","src":"Y"},{"id":10913,"vol":2,"day":18,"w":"non sequitur","m":"잘못된 결론","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"His argument ended in a non sequitur.","ko":"그의 주장은 잘못된 결론으로 끝났다."}},{"id":10914,"vol":2,"day":18,"w":"nonconformist","m":"순종하지 않는 사람 / 비국교도(영국의)","p":[{"d":"순종하지 않는 사람 / 비국교도(영국의)","s":["dissenter"]}],"s":["dissenter"],"r":"non(not/부정) + conform(따르다) + -ist(~하는 사람) → 따르지 않는 이 → 순종하지 않는 사람, 비국교도","type":"word","src":"Y"},{"id":10915,"vol":2,"day":18,"w":"nonflammable","m":"잘 타지 않는 / 불연성의","p":[],"s":[],"r":"non(not/부정) + flammable(타기 쉬운) → 타지 않는 → 잘 타지 않는, 불연성의","type":"word","src":"Y"},{"id":10916,"vol":2,"day":18,"w":"non-fungible token (NFT)","m":"대체 불가능 토큰(디지털 파일 정품 인증서)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The artist sold the work as a non-fungible token.","ko":"그 예술가는 그 작품을 대체 불가능 토큰으로 팔았다."}},{"id":10917,"vol":2,"day":18,"w":"nongovernmental organization","m":"비정부 기구(NGO)","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The nongovernmental organization aids refugees.","ko":"그 비정부 기구는 난민을 돕는다."}},{"id":10918,"vol":2,"day":18,"w":"non-involvement","m":"무관여 / 비개입","p":[],"s":[],"r":"non(not/부정) + involvement(관여) → 관여하지 않음 → 무관여, 비개입","type":"word","src":"Y"},{"id":10919,"vol":2,"day":18,"w":"nonlinear","m":"비선형적인","p":[],"s":[],"r":"non(not/부정) + linear(선형의) → 선형이 아닌 → 비선형적인","type":"word","src":"Y"},{"id":10920,"vol":2,"day":18,"w":"no-no","m":"해서는 안 되는 것","p":[],"s":[],"r":"no(안 되는) + no(안 되는) → 하지 말아야 할 것 → 해서는 안 되는 것","type":"word","src":"Y"},{"id":10921,"vol":2,"day":18,"w":"nonpareil","m":"비길 데 없는 / 최상품","p":[{"d":"비길 데 없는","s":["peerless","matchless","supreme"]}],"s":["peerless","matchless","supreme"],"r":"non(not) + pareil(equal/동등한) → 동등한 것이 없는 → 비길 데 없는