ed name"],"r":"pseudo(false/가짜) + nym(name/이름) → 가짜 이름 → 필명, 익명","type":"word","src":"Y"},{"id":5809,"vol":1,"day":45,"w":"pseudo-science","m":"사이비 과학","p":[],"s":[],"r":"pseudo(false/거짓) + science(과학) → 과학인 척하는 것 → 사이비 과학","type":"word","src":"Y"},{"id":5810,"vol":1,"day":45,"w":"psychiatry","m":"정신 의학","p":[],"s":[],"r":"psych(mind/정신) + iatr(heal/치료) + -y(형용사형) → 정신을 치료하는 학문 → 정신 의학","type":"word","src":"Y"},{"id":5811,"vol":1,"day":45,"w":"psychoanalysis","m":"정신 분석학","p":[],"s":[],"r":"psycho(mind/정신) + analysis(분석) → 정신을 파고들어 분석함 → 정신 분석학","type":"word","src":"Y"},{"id":5812,"vol":1,"day":45,"w":"psychology","m":"심리학 / 심리","p":[{"d":"심리학 / 심리","s":["mentality"]}],"s":["mentality"],"r":"psycho(soul/영혼) + log(study/연구) → 영혼을 연구하는 것 → 심리학","type":"word","src":"Y"},{"id":5813,"vol":1,"day":45,"w":"puberty","m":"사춘기","p":[{"d":"사춘기","s":["adolescence"]}],"s":["adolescence"],"r":"pub(adult/성인) + -erty(형용사형) → 성인이 되는 시기 → 사춘기","type":"word","src":"Y"},{"id":5814,"vol":1,"day":45,"w":"publicity","m":"널리 알려짐 / 명성 / 홍보","p":[{"d":"널리 알려짐 / 명성","s":["celebrity"]}],"s":["celebrity"],"r":"public(공개된) + -ity(명사형) → 널리 알려짐 → 명성, 홍보","type":"word","src":"Y"},{"id":5815,"vol":1,"day":45,"w":"publish","m":"출판하다 / 공표하다","p":[],"s":[],"r":"publ(ic)(public/공개) + -ish(~같은) → 널리 알리다 → 출판하다, 공표하다","type":"word","src":"Y"},{"id":5816,"vol":1,"day":45,"w":"puerile","m":"유치한 / 바보 같은","p":[{"d":"유치한","s":["childish"]},{"d":"바보 같은","s":["inane"]}],"s":["childish","inane"],"r":"puer(child/아이) + -ile(형용사형) → 아이 같은 → 어린아이 같은, 유치한","type":"word","src":"Y"},{"id":5817,"vol":1,"day":45,"w":"pugnacious","m":"호전적인 / 공격적인","p":[{"d":"호전적인","s":["bellicose","belligerent"]},{"d":"공격적인","s":["truculent"]}],"s":["bellicose","belligerent","truculent"],"r":"pugn(fist/주먹) + -acious(형용사형) → 주먹을 쓰는 성질 → 호전적인, 싸움하기 좋아하는","type":"word","src":"Y"},{"id":5818,"vol":1,"day":45,"w":"pull a long face","m":"시무룩한 표정을 짓다","p":[{"d":"시무룩한 표정을 짓다","s":["wear a gloomy expression"]}],"s":["wear a gloomy expression"],"r":"","type":"phrase","src":"Y","ex":{"en":"He pulled a long face when he lost the game.","ko":"그는 경기에서 지자 시무룩한 표정을 지었다."}},{"id":5819,"vol":1,"day":45,"w":"pull down","m":"끌어내리다 / 무너뜨리다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The old statue was pulled down last year.","ko":"그 낡은 동상은 작년에 끌어내려졌다."}},{"id":5820,"vol":1,"day":45,"w":"pull off","m":"잡아 뜯다 / 잘 해내다","p":[{"d":"잡아 뜯다","s":["tear away"]}],"s":["tear away"],"r":"","type":"phrase","src":"Y","ex":{"en":"Against all odds, she pulled off the win.","ko":"모든 역경에도 불구하고 그녀는 승리를 잘 해냈다."}},{"id":5821,"vol":1,"day":45,"w":"pull one's finger out","m":"다시 열심히 일하기 시작하다","p":[{"d":"다시 열심히 일하기 시작하다","s":["stop being lazy"]}],"s":["stop being lazy"],"r":"","type":"phrase","src":"Y","ex":{"en":"You need to pull your finger out and finish this.","ko":"너는 다시 열심히 해서 이것을 끝내야 한다."}},{"id":5822,"vol":1,"day":45,"w":"pull one's leg","m":"놀리다 / 속이다","p":[{"d":"놀리다","s":["tease"]},{"d":"속이다","s":["deceive"]}],"s":["tease","deceive"],"r":"","type":"phrase","src":"Y","ex":{"en":"Don't believe him; he's just pulling your leg.","ko":"그를 믿지 마라. 그는 그냥 너를 놀리는 것이다."}},{"id":5823,"vol":1,"day":45,"w":"pull one's weight","m":"자신의 역할을 다하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"Everyone must pull their weight on this team.","ko":"이 팀에서는 모두가 자신의 역할을 다해야 한다."}},{"id":5824,"vol":1,"day":45,"w":"pull oneself together","m":"마음을 가라앉히다","p":[{"d":"마음을 가라앉히다","s":["get hold of oneself"]}],"s":["get hold of oneself"],"r":"","type":"phrase","src":"Y","ex":{"en":"Take a moment to pull yourself together.","ko":"잠시 마음을 가라앉혀라."}},{"id":5825,"vol":1,"day":45,"w":"pull over","m":"차를 길가에 세우다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"The driver pulled over to check the map.","ko":"그 운전자는 지도를 확인하려고 차를 길가에 세웠다."}},{"id":5826,"vol":1,"day":45,"w":"pull rank","m":"지위를 악용하다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"He pulled rank to get the best office.","ko":"그는 가장 좋은 사무실을 얻으려고 지위를 악용했다."}},{"id":5827,"vol":1,"day":45,"w":"pull through","m":"극복하다 / 회복하다","p":[{"d":"극복하다 / 회복하다","s":["recuperate"]}],"s":["recuperate"],"r":"","type":"phrase","src":"Y","ex":{"en":"The doctors were sure she would pull through.","ko":"의사들은 그녀가 회복할 것이라고 확신했다."}},{"id":5828,"vol":1,"day":45,"w":"pull together","m":"협력하다 / 합치다","p":[],"s":[],"r":"","type":"phrase","src":"Y","ex":{"en":"If we all pull together, we can finish on time.","ko":"우리 모두 협력하면 제시간에 끝낼 수 있다."}},{"id":5829,"vol":1,"day":45,"w":"pull up","m":"빼다 / 멈추다","p":[{"d":"빼다","s":["draw"]},{"d":"멈추다","s":["bring to a halt"]}],"s":["draw","bring to a halt"],"r":"","type":"phrase","src":"Y","ex":{"en":"The taxi pulled up in front of the hotel.","ko":"그 택시는 호텔 앞에 멈췄다."}},{"id":5830,"vol":1,"day":45,"w":"pull up stakes","m":"떠나다 / 이사하다","p":[{"d":"떠나다 / 이사하다","s":["move away"]}],"s":["move away"],"r":"","type":"phrase","src":"Y","ex":{"en":"They pulled up stakes and moved to another city.","ko":"그들은 짐을 싸서 다른 도시로 이사했다."}},{"id":5831,"vol":1,"day":45,"w":"pulsate","m":"맥박이 뛰다 / 고동치다","p":[{"d":"맥박이 뛰다 / 고동치다","s":["throb"]}],"s":["throb"],"r":"puls(beat/치다) + -ate(동사형) → 계속 치다 → 맥박이 뛰다, 고동치다","type":"word","src":"Y"},{"id":5832,"vol":1,"day":45,"w":"pun","m":"말장난","p":[{"d":"말장난","s":["play on words"]}],"s":["play on words"],"r":"[pundit 또는 이탈리아어 puntiglio에서] → 말을 살짝 비튼 재치 → 말장난","type":"word","src":"Y"},{"id":5833,"vol":1,"day":45,"w":"punch","m":"세게 치다 / 구멍을 뚫다 / 주먹질 / 박력 / 구멍 뚫는 도구 / 펀치(음료)","p":[],"s":[],"r":"[중세 영어] punchen(찌르다) ← 라틴어 pungere(prick/찌르다) → 세게 찌르다 → 세게 치다, 구멍을 뚫다","type":"word","src":"Y"},{"id":5834,"vol":1,"day":45,"w":"punctilious","m":"꼼꼼한 / 격식을 차리는","p":[{"d":"꼼꼼한","s":["meticulous","scrupulous","conscientious"]}],"s":["meticulous","scrupulous","conscientious"],"r":"punct(point/점) + -ilious(형용사형) → 점 하나까지 신경 쓰는 → 세심한, 꼼꼼한","type":"word","src":"Y"},{"id":5835,"vol":1,"day":45,"w":"punctual","m":"시간을 엄수하는","p":[{"d":"시간을 엄수하는","s":["on time"]}],"s":["on time"],"r":"punct(point/점) + -ual(형용사형) → 정확한 점처럼 → 시간을 엄수하는","type":"word","src":"Y"},{"id":5836,"vol":1,"day":45,"w":"punctuate","m":"~에 구두점을 찍다 / 강조하다 / 중단시키다(말을) / ~의 여기저기에 위치하다","p":[{"d":"~에 구두점을 찍다 / 강조하다","s":["emphasize"]}],"s":["emphasize"],"r":"punct(point/점) + -uate(동사형) → 점으로 표시하다 → 구두점을 찍다, 강조하다","type":"word","src":"Y"},{"id":5837,"vol":1,"day":45,"w":"puncture","m":"구멍을 뚫다 / 상처를 입히다 / 망쳐 놓다 / 찌름 / 펑크","p":[{"d":"구멍을 뚫다","s":["pierce"]}],"s":["pierce"],"r":"punct(prick/찌르다) + -ure(명사형) → 찔러서 생긴 구멍 → 펑크, 구멍을 내다","type":"word","src":"Y"}]